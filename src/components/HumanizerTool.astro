---
---
<section id="tool" class="w-full max-w-7xl mx-auto space-y-6">
  <div class="rounded-2xl border border-zinc-200/80 bg-white shadow-sm overflow-hidden flex flex-col p-6 sm:p-8">
    <div class="mb-6">
      <label for="tone-selector" class="block text-sm font-semibold text-zinc-900 mb-3">Tone of voice</label>
      <div id="tone-selector" class="flex flex-wrap gap-2" role="radiogroup" aria-label="Writing tone">
        <button type="button" role="radio" aria-checked="true" aria-label="Standard tone" class="tone-btn active" data-tone="standard">Standard</button>
        <button type="button" role="radio" aria-checked="false" aria-label="Academic tone" class="tone-btn" data-tone="academic">Academic</button>
        <button type="button" role="radio" aria-checked="false" aria-label="Business tone" class="tone-btn" data-tone="business">Business</button>
        <button type="button" role="radio" aria-checked="false" aria-label="Casual tone" class="tone-btn" data-tone="casual">Casual</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative">
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-zinc-100 -translate-x-1/2"></div>
      
      <div class="flex flex-col relative group">
        <div class="flex items-center justify-between mb-3">
          <label for="input-text" class="text-sm font-semibold text-zinc-900">Input</label>
          <button type="button" id="clear-btn" class="text-xs font-medium text-zinc-500 hover:text-zinc-900 transition-colors">Clear</button>
        </div>
        <textarea
          id="input-text"
          class="w-full h-64 sm:h-80 rounded-xl border border-zinc-200 bg-zinc-50 p-4 text-[14px] leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all resize-none"
          placeholder="Paste your AI-generated text here..."
        ></textarea>
        <div class="mt-3 text-xs text-zinc-500 font-medium">
          <span id="input-count">0 chars / 0 words</span>
        </div>
      </div>

      <div class="flex flex-col relative">
        <div class="flex items-center justify-between mb-3">
          <label for="output-text" class="text-sm font-semibold text-zinc-900 flex items-center gap-2">
            Output
            <span class="flex h-2 w-2 rounded-full bg-indigo-500"></span>
          </label>
          <button type="button" id="copy-btn" class="hidden text-xs font-medium text-indigo-600 hover:text-indigo-700 transition-colors flex items-center gap-1">
            <svg xmlns="http://www.w0.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-3.5">
              <path fill-rule="evenodd" d="M15.988 3.012A2.25 2.25 0 0 1 18 5.25v6.5A2.25 2.25 0 0 1 15.75 14H13.5V7A2.5 2.5 0 0 0 11 4.5H8.128a2.252 2.252 0 0 1 1.884-1.488A2.25 2.25 0 0 1 12.25 1h1.5a2.25 2.25 0 0 1 2.238 2.012ZM11.5 3.25a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 .75.75v.25h-3v-.25Z" clip-rule="evenodd" />
              <path fill-rule="evenodd" d="M2 7a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7Zm2 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75Zm0 3.5a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
            </svg>
            Copy
          </button>
        </div>
        <textarea
          id="output-text"
          class="w-full h-64 sm:h-80 rounded-xl border-0 ring-1 ring-inset ring-zinc-200 bg-white p-4 text-[14px] leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500/50 transition-all resize-none"
          readonly
          placeholder="Your humanized text will appear here..."
        ></textarea>
        <div class="mt-3 text-xs text-zinc-500 font-medium">
          <span id="output-count">0 chars / 0 words</span>
        </div>
      </div>
    </div>

    <div class="mt-8 flex justify-center border-t border-zinc-100 pt-8">
      <button
        type="button"
        id="humanize-btn"
        class="btn btn--primary px-8 text-sm disabled:opacity-50 disabled:cursor-not-allowed group relative overflow-hidden"
      >
        <span class="relative z-10 flex items-center gap-2">
          <svg xmlns="http://www.w0.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4">
            <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd" />
          </svg>
          Humanize Text
        </span>
      </button>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .tone-btn {
    @apply px-4 py-2 rounded-lg text-sm font-medium border border-zinc-200 bg-white text-zinc-600 transition-all duration-200 hover:border-zinc-300 hover:bg-zinc-50 hover:text-zinc-900 active:scale-95;
  }
  .tone-btn.active {
    @apply border-indigo-200 bg-indigo-50 text-indigo-700 shadow-sm ring-1 ring-indigo-500/10;
  }
</style>

<script>
  // --- Broad synonym map: covers both AI-typical and everyday words ---
  const synonymMap: Record<string, string[]> = {
    // AI-typical formal words
    'utilize': ['use', 'work with', 'rely on'],
    'implement': ['set up', 'put in place', 'roll out'],
    'facilitate': ['help', 'make easier', 'enable'],
    'demonstrate': ['show', 'highlight', 'prove'],
    'comprehensive': ['complete', 'full', 'all-around'],
    'subsequently': ['then', 'after that', 'next'],
    'furthermore': ['also', 'plus', 'on top of that'],
    'nevertheless': ['still', 'even so', 'that said'],
    'consequently': ['so', 'as a result', 'because of this'],
    'additionally': ['also', 'plus', 'and'],
    'significantly': ['greatly', 'a lot', 'noticeably'],
    'approximately': ['about', 'around', 'roughly'],
    'immediately': ['right away', 'at once', 'straight away'],
    'particularly': ['especially', 'mainly', 'most of all'],
    'essentially': ['basically', 'really', 'at its core'],
    'effectively': ['well', 'in practice', 'successfully'],
    'incorporate': ['include', 'add', 'bring in'],
    'leverage': ['use', 'take advantage of', 'tap into'],
    'optimize': ['improve', 'fine-tune', 'make better'],
    'streamline': ['simplify', 'speed up', 'smooth out'],
    'mitigate': ['reduce', 'lessen', 'cut down on'],
    'prioritize': ['focus on', 'put first', 'zero in on'],
    'methodology': ['method', 'approach', 'way'],
    'delve': ['dig into', 'explore', 'look at'],
    'crucial': ['key', 'important', 'vital'],
    'robust': ['strong', 'solid', 'reliable'],
    'innovative': ['new', 'fresh', 'creative'],
    'meticulous': ['careful', 'thorough', 'detailed'],
    // Common everyday words for broader coverage
    'provide': ['give', 'offer', 'deliver'],
    'obtain': ['get', 'grab', 'pick up'],
    'require': ['need', 'call for', 'take'],
    'assist': ['help', 'support', 'give a hand'],
    'purchase': ['buy', 'get', 'pick up'],
    'sufficient': ['enough', 'plenty of', 'adequate'],
    'numerous': ['many', 'lots of', 'a bunch of'],
    'attempt': ['try', 'go for', 'take a shot at'],
    'commence': ['start', 'begin', 'kick off'],
    'terminate': ['end', 'stop', 'wrap up'],
    'indicate': ['show', 'point to', 'suggest'],
    'determine': ['figure out', 'find out', 'decide'],
    'establish': ['set up', 'create', 'build'],
    'maintain': ['keep', 'hold onto', 'stick with'],
    'achieve': ['reach', 'hit', 'pull off'],
    'enhance': ['improve', 'boost', 'level up'],
    'generate': ['create', 'produce', 'come up with'],
    'select': ['choose', 'pick', 'go with'],
    'modify': ['change', 'tweak', 'adjust'],
    'ensure': ['make sure', 'guarantee', 'see to it that'],
    'various': ['different', 'a range of', 'all kinds of'],
    'however': ['but', 'though', 'then again'],
    'therefore': ['so', 'that\'s why', 'because of that'],
    'although': ['even though', 'while', 'despite the fact that'],
    'regarding': ['about', 'when it comes to', 'as for'],
    'concerning': ['about', 'around', 'related to'],
    'typically': ['usually', 'most of the time', 'as a rule'],
    'frequently': ['often', 'a lot', 'all the time'],
    'occasionally': ['sometimes', 'now and then', 'once in a while'],
    'rapidly': ['quickly', 'fast', 'in no time'],
    'extremely': ['very', 'super', 'incredibly'],
    'instantly': ['right away', 'in a flash', 'on the spot'],
    'entirely': ['completely', 'fully', 'all the way'],
    'precisely': ['exactly', 'spot-on', 'right'],
    'capable': ['able', 'up to the task', 'equipped'],
    'transform': ['change', 'turn into', 'reshape'],
    'identical': ['the same', 'matching', 'alike'],
    'individual': ['person', 'someone', 'user'],
    'component': ['part', 'piece', 'element'],
    'specific': ['particular', 'certain', 'exact'],
    'appropriate': ['right', 'fitting', 'suitable'],
    'significant': ['big', 'major', 'important'],
    'opportunity': ['chance', 'opening', 'shot'],
    'challenge': ['problem', 'hurdle', 'tough spot'],
    'consider': ['think about', 'look at', 'weigh'],
    'excellent': ['great', 'awesome', 'top-notch'],
    'content': ['writing', 'text', 'material'],
    'rewrite': ['rework', 'redo', 'rephrase'],
    'natural': ['human-like', 'organic', 'authentic'],
    'detection': ['scanning', 'checking', 'screening'],
    'quality': ['caliber', 'standard', 'grade'],
  };

  // Phrase-level replacements (checked before word-level)
  const phraseMap: Record<string, string[]> = {
    'in order to': ['to', 'so you can', 'for'],
    'due to the fact that': ['because', 'since', 'as'],
    'at the end of the day': ['ultimately', 'in the end', 'when it comes down to it'],
    'a wide range of': ['many', 'various', 'all sorts of'],
    'it is important to note': ['keep in mind', 'worth noting', 'note that'],
    'it is worth mentioning': ['also', 'notably', 'on that note'],
    'in conclusion': ['to sum up', 'all in all', 'in short'],
    'on the other hand': ['then again', 'but', 'at the same time'],
    'as a result': ['so', 'because of this', 'that\'s why'],
    'for example': ['like', 'say', 'for instance'],
    'in addition': ['also', 'plus', 'and'],
    'such as': ['like', 'including', 'for example'],
    'make sure': ['be sure to', 'double-check that', 'see that'],
    'a lot of': ['plenty of', 'tons of', 'loads of'],
    'as well as': ['along with', 'and', 'plus'],
    'with regard to': ['about', 'when it comes to', 'as for'],
    'in terms of': ['when it comes to', 'for', 'as far as'],
    'is able to': ['can', 'has the ability to', 'is capable of'],
    'has the ability to': ['can', 'is able to', 'knows how to'],
  };

  // Contraction map
  const contractionMap: Record<string, string> = {
    'do not': 'don\'t', 'does not': 'doesn\'t', 'did not': 'didn\'t',
    'is not': 'isn\'t', 'are not': 'aren\'t', 'was not': 'wasn\'t',
    'were not': 'weren\'t', 'will not': 'won\'t', 'would not': 'wouldn\'t',
    'could not': 'couldn\'t', 'should not': 'shouldn\'t', 'cannot': 'can\'t',
    'can not': 'can\'t', 'have not': 'haven\'t', 'has not': 'hasn\'t',
    'had not': 'hadn\'t', 'it is': 'it\'s', 'that is': 'that\'s',
    'there is': 'there\'s', 'what is': 'what\'s', 'who is': 'who\'s',
    'i am': 'I\'m', 'you are': 'you\'re', 'we are': 'we\'re',
    'they are': 'they\'re', 'i will': 'I\'ll', 'you will': 'you\'ll',
    'we will': 'we\'ll', 'they will': 'they\'ll', 'i have': 'I\'ve',
    'you have': 'you\'ve', 'we have': 'we\'ve', 'they have': 'they\'ve',
    'i would': 'I\'d', 'you would': 'you\'d', 'we would': 'we\'d',
    'they would': 'they\'d', 'let us': 'let\'s',
  };

  const toneConfig: Record<string, {
    fillers: string[];
    starters: string[];
    connectors: string[];
    useContractions: boolean;
    fillerRate: number;
    starterRate: number;
    splitRate: number;
  }> = {
    standard: {
      fillers: ['actually', 'honestly', 'really', 'pretty much', 'in fact'],
      starters: ['Look,', 'Here\'s the thing —', 'So,', 'The thing is,', 'Honestly,', 'Truth be told,'],
      connectors: [' — and ', '. Plus, ', '. Also, ', ', and honestly '],
      useContractions: true,
      fillerRate: 0.35,
      starterRate: 0.3,
      splitRate: 0.25,
    },
    academic: {
      fillers: ['notably', 'indeed', 'in particular', 'specifically', 'importantly'],
      starters: ['It is evident that', 'Research indicates that', 'One should note that', 'Upon closer examination,', 'Importantly,'],
      connectors: ['; moreover, ', '. In addition, ', '. Furthermore, ', '; in particular, '],
      useContractions: false,
      fillerRate: 0.25,
      starterRate: 0.25,
      splitRate: 0.15,
    },
    business: {
      fillers: ['in practice', 'from our experience', 'typically', 'as a rule', 'realistically'],
      starters: ['From a practical standpoint,', 'In practice,', 'The key takeaway here is that', 'What matters most is that', 'Bottom line —'],
      connectors: ['. More importantly, ', '. On top of that, ', '. That said, ', ' — and crucially, '],
      useContractions: true,
      fillerRate: 0.3,
      starterRate: 0.3,
      splitRate: 0.2,
    },
    casual: {
      fillers: ['like', 'basically', 'honestly', 'just', 'literally', 'pretty much', 'tbh'],
      starters: ['So yeah,', 'Okay so,', 'Real talk —', 'Here\'s the deal:', 'Not gonna lie,', 'Honestly?', 'Look,'],
      connectors: [' — and like, ', '. Oh and also, ', '. Plus, ', ', which is pretty cool because '],
      useContractions: true,
      fillerRate: 0.45,
      starterRate: 0.4,
      splitRate: 0.3,
    },
  };

  function pick<T>(arr: T[]): T {
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function chance(rate: number): boolean {
    return Math.random() < rate;
  }

  function capitalize(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function humanizeText(text: string, tone: string): string {
    if (!text.trim()) return '';

    let result = text;
    const cfg = toneConfig[tone] || toneConfig.standard;

    // Step 1: Phrase-level replacements (longer patterns first)
    for (const [phrase, replacements] of Object.entries(phraseMap)) {
      const regex = new RegExp(phrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
      result = result.replace(regex, () => pick(replacements));
    }

    // Step 2: Word-level synonym replacement
    for (const [word, replacements] of Object.entries(synonymMap)) {
      const regex = new RegExp(`\\b${word}\\b`, 'gi');
      result = result.replace(regex, (match) => {
        if (!chance(0.7)) return match; // 70% chance to replace each occurrence
        const rep = pick(replacements);
        return match[0] === match[0].toUpperCase() ? capitalize(rep) : rep;
      });
    }

    // Step 3: Apply contractions (for non-academic tones)
    if (cfg.useContractions) {
      for (const [full, contracted] of Object.entries(contractionMap)) {
        const regex = new RegExp(`\\b${full}\\b`, 'gi');
        result = result.replace(regex, () => contracted);
      }
    }

    // Step 4: Sentence-level transformations
    const sentences = result.match(/[^.!?]+[.!?]+/g) || [result];
    const processed: string[] = [];

    for (let i = 0; i < sentences.length; i++) {
      let s = sentences[i].trim();

      // Split long sentences (>15 words) at a comma
      if (chance(cfg.splitRate)) {
        const words = s.split(' ');
        if (words.length > 15) {
          const commaIdx = s.indexOf(',', Math.floor(s.length * 0.3));
          if (commaIdx > 10 && commaIdx < s.length - 10) {
            const firstPart = s.slice(0, commaIdx).trim();
            const secondPart = s.slice(commaIdx + 1).trim();
            const ending = s.match(/[.!?]+$/)?.[0] || '.';
            s = firstPart + ending + ' ' + capitalize(secondPart);
          }
        }
      }

      // Add sentence starters to some non-first sentences
      if (i > 0 && chance(cfg.starterRate)) {
        const starter = pick(cfg.starters);
        // Lowercase the first char of the existing sentence
        const body = s.charAt(0).toLowerCase() + s.slice(1);
        s = `${starter} ${body}`;
      }

      // Insert filler words
      if (chance(cfg.fillerRate)) {
        const filler = pick(cfg.fillers);
        const words = s.split(' ');
        if (words.length > 3) {
          // Insert after 1st-3rd word
          const pos = Math.min(1 + Math.floor(Math.random() * 3), words.length - 1);
          words.splice(pos, 0, filler);
          s = words.join(' ');
        }
      }

      // Casual: sometimes swap period for exclamation
      if (tone === 'casual' && chance(0.2) && s.endsWith('.')) {
        s = s.slice(0, -1) + '!';
      }

      // Occasionally merge two short sentences
      if (i < sentences.length - 1 && chance(0.2)) {
        const nextS = sentences[i + 1]?.trim();
        if (nextS && s.split(' ').length < 10 && nextS.split(' ').length < 10) {
          const connector = pick(cfg.connectors);
          const nextBody = nextS.replace(/[.!?]+$/, '');
          const ending = nextS.match(/[.!?]+$/)?.[0] || '.';
          s = s.replace(/[.!?]+$/, '') + connector + nextBody.charAt(0).toLowerCase() + nextBody.slice(1) + ending;
          i++; // skip next sentence since we merged it
        }
      }

      processed.push(s);
    }

    // Step 5: Minor post-processing — vary spacing and clean up
    let output = processed.join(' ');

    // Remove double spaces
    output = output.replace(/ {2,}/g, ' ');
    // Fix capitalization after periods
    output = output.replace(/([.!?])\s+([a-z])/g, (_, punct, char) => `${punct} ${char.toUpperCase()}`);

    return output.trim();
  }

  function countWords(text: string): number {
    return text.trim() ? text.trim().split(/\s+/).length : 0;
  }

  function updateCount(elementId: string, text: string) {
    const el = document.getElementById(elementId);
    if (el) {
      el.textContent = `${text.length} chars / ${countWords(text)} words`;
    }
  }

  // Tone selector
  document.querySelectorAll('.tone-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tone-btn').forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-checked', 'true');
    });
  });

  // Input counter
  const inputEl = document.getElementById('input-text') as HTMLTextAreaElement;
  const outputEl = document.getElementById('output-text') as HTMLTextAreaElement;
  const humanizeBtn = document.getElementById('humanize-btn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  inputEl?.addEventListener('input', () => {
    updateCount('input-count', inputEl.value);
  });

  // Humanize action
  humanizeBtn?.addEventListener('click', () => {
    const text = inputEl?.value || '';
    if (!text.trim()) return;

    const activeTone = document.querySelector('.tone-btn.active') as HTMLElement;
    const tone = activeTone?.dataset.tone || 'standard';

    humanizeBtn.disabled = true;
    const originalText = humanizeBtn.innerHTML;
    humanizeBtn.innerHTML = '<span class="relative z-10 flex items-center gap-2">Processing...</span>';

    // Simulate brief processing delay
    setTimeout(() => {
      const result = humanizeText(text, tone);
      if (outputEl) {
        outputEl.value = result;
        updateCount('output-count', result);
      }
      copyBtn?.classList.remove('hidden');
      humanizeBtn.disabled = false;
      humanizeBtn.innerHTML = originalText;
    }, 600);
  });

  // Copy to clipboard
  copyBtn?.addEventListener('click', async () => {
    const text = outputEl?.value || '';
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML = '<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.815a.75.75 0 0 1 1.05-.145Z" clip-rule="evenodd" /></svg> Copied!</span>';
      setTimeout(() => {
        copyBtn.innerHTML = original;
      }, 1500);
    } catch {
      outputEl?.select();
    }
  });

  // Clear
  clearBtn?.addEventListener('click', () => {
    if (inputEl) inputEl.value = '';
    if (outputEl) outputEl.value = '';
    updateCount('input-count', '');
    updateCount('output-count', '');
    copyBtn?.classList.add('hidden');
  });
</script>
