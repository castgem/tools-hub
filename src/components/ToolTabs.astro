---
---
<section id="tools" class="w-full max-w-7xl mx-auto space-y-6">
  <div class="rounded-2xl border border-zinc-200/80 bg-white shadow-sm overflow-hidden flex flex-col">
    <div class="border-b border-zinc-100 bg-zinc-50/50 p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h2 class="text-base font-semibold tracking-tight text-zinc-900">Developer Toolkit</h2>
      </div>
      
      <div class="flex p-1 rounded-lg bg-zinc-100/80 ring-1 ring-zinc-900/5 overflow-x-auto scrollbar-hide" role="tablist" aria-label="Developer tools">
        <button role="tab" class="tab-btn active whitespace-nowrap" data-tab="regex" aria-selected="true" aria-controls="panel-regex">
          Regex
        </button>
        <button role="tab" class="tab-btn whitespace-nowrap" data-tab="base64" aria-selected="false" aria-controls="panel-base64">
          Base64
        </button>
        <button role="tab" class="tab-btn whitespace-nowrap" data-tab="cron" aria-selected="false" aria-controls="panel-cron">
          Cron
        </button>
        <button role="tab" class="tab-btn whitespace-nowrap" data-tab="sql" aria-selected="false" aria-controls="panel-sql">
          SQL Formatter
        </button>
      </div>
    </div>

    <div class="p-5 sm:p-6 lg:p-8 bg-zinc-50/30">
      <!-- Regex Panel -->
      <div id="panel-regex" role="tabpanel" class="tool-panel active" data-panel="regex">
        <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="flex flex-col gap-5 rounded-2xl border border-zinc-200/80 bg-white shadow-sm p-5 sm:p-6">
            <div>
              <label for="regex-pattern" class="block text-[13px] font-medium text-zinc-700 mb-1.5">Pattern</label>
              <div class="flex items-center gap-2 rounded-xl border border-zinc-200 bg-zinc-50 px-3 focus-within:border-zinc-400 focus-within:ring-4 focus-within:ring-zinc-900/5 transition-all">
                <span class="text-zinc-400 font-mono text-lg">/</span>
                <input id="regex-pattern" type="text" class="w-full bg-transparent border-0 py-3 text-[14px] font-mono text-zinc-900 placeholder:text-zinc-400 focus:ring-0" placeholder="e.g. (\d{4})-(\d{2})-(\d{2})" />
                <span class="text-zinc-400 font-mono text-lg">/</span>
                <div class="flex gap-1 ml-2 pl-2 border-l border-zinc-200">
                  <label class="cursor-pointer group relative flex items-center justify-center h-7 w-7 rounded border border-transparent has-[:checked]:border-zinc-200 has-[:checked]:bg-white transition-colors">
                    <input type="checkbox" id="flag-g" class="peer sr-only" checked />
                    <span class="text-xs font-mono font-medium text-zinc-400 peer-checked:text-zinc-900">g</span>
                  </label>
                  <label class="cursor-pointer group relative flex items-center justify-center h-7 w-7 rounded border border-transparent has-[:checked]:border-zinc-200 has-[:checked]:bg-white transition-colors">
                    <input type="checkbox" id="flag-i" class="peer sr-only" />
                    <span class="text-xs font-mono font-medium text-zinc-400 peer-checked:text-zinc-900">i</span>
                  </label>
                  <label class="cursor-pointer group relative flex items-center justify-center h-7 w-7 rounded border border-transparent has-[:checked]:border-zinc-200 has-[:checked]:bg-white transition-colors">
                    <input type="checkbox" id="flag-m" class="peer sr-only" />
                    <span class="text-xs font-mono font-medium text-zinc-400 peer-checked:text-zinc-900">m</span>
                  </label>
                  <label class="cursor-pointer group relative flex items-center justify-center h-7 w-7 rounded border border-transparent has-[:checked]:border-zinc-200 has-[:checked]:bg-white transition-colors">
                    <input type="checkbox" id="flag-s" class="peer sr-only" />
                    <span class="text-xs font-mono font-medium text-zinc-400 peer-checked:text-zinc-900">s</span>
                  </label>
                </div>
              </div>
            </div>
            <div>
              <label for="regex-input" class="block text-[13px] font-medium text-zinc-700 mb-1.5">Test String</label>
              <textarea id="regex-input" class="w-full h-40 rounded-xl border border-zinc-200 bg-zinc-50 p-3.5 text-[14px] font-mono leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all resize-y" placeholder="Paste test string here...&#10;e.g. 2026-03-24 is today"></textarea>
            </div>
          </div>
          
          <div class="flex flex-col h-full min-h-[350px] rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 p-3">
              <div class="flex items-center gap-2 px-1">
                <div class="flex gap-1.5">
                  <div class="h-2.5 w-2.5 rounded-full bg-red-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
                </div>
                <span class="ml-2 text-xs font-medium text-zinc-400">Matches</span>
              </div>
              <span id="regex-count" class="text-[11px] font-semibold uppercase tracking-wider text-zinc-400 bg-zinc-800 px-2 py-0.5 rounded">0 matches</span>
            </div>
            <div class="flex-1 p-4 bg-zinc-950 overflow-y-auto space-y-4">
              <div id="regex-output" class="font-mono text-[13px] leading-relaxed text-zinc-300 break-all whitespace-pre-wrap">Enter regex pattern and test string.</div>
              <div id="regex-groups" class="pt-4 border-t border-zinc-800/50 hidden">
                <span class="block text-xs font-semibold text-zinc-500 mb-2 uppercase tracking-wider">Groups</span>
                <pre id="regex-groups-content" class="font-mono text-[12px] leading-relaxed text-zinc-400"></pre>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Base64 Panel -->
      <div id="panel-base64" role="tabpanel" class="tool-panel hidden" data-panel="base64">
        <div class="grid gap-6 lg:grid-cols-[1fr_1fr] lg:items-start">
          <div class="flex flex-col gap-4 rounded-2xl border border-zinc-200/80 bg-white shadow-sm p-5 sm:p-6">
            <div class="flex p-1 rounded-lg bg-zinc-100/80 ring-1 ring-zinc-900/5 w-fit">
              <button id="b64-encode-btn" class="mode-btn active" type="button">Encode</button>
              <button id="b64-decode-btn" class="mode-btn" type="button">Decode</button>
            </div>
            <div>
              <label for="b64-input" class="block text-[13px] font-medium text-zinc-700 mb-1.5">Input</label>
              <textarea id="b64-input" class="w-full h-64 rounded-xl border border-zinc-200 bg-zinc-50 p-3.5 text-[14px] font-mono leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all resize-y" placeholder="Enter text to encode/decode..."></textarea>
            </div>
          </div>
          
          <div class="flex flex-col h-full min-h-[350px] rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 p-3">
              <div class="flex items-center gap-2 px-1">
                <div class="flex gap-1.5">
                  <div class="h-2.5 w-2.5 rounded-full bg-red-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
                </div>
                <span class="ml-2 text-xs font-medium text-zinc-400">Output</span>
              </div>
              <button id="b64-copy" class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-zinc-100 btn-copy" type="button">
                Copy
              </button>
            </div>
            <textarea id="b64-output" class="w-full flex-1 resize-none border-0 bg-zinc-950 p-4 font-mono text-[13px] leading-relaxed text-zinc-300 focus:outline-none focus:ring-0" readonly></textarea>
          </div>
        </div>
      </div>

      <!-- Cron Panel -->
      <div id="panel-cron" role="tabpanel" class="tool-panel hidden" data-panel="cron">
        <div class="grid gap-6 lg:grid-cols-[1fr_1fr] lg:items-start">
          <div class="flex flex-col gap-6 rounded-2xl border border-zinc-200/80 bg-white shadow-sm p-5 sm:p-6">
            <div>
              <label for="cron-expression" class="block text-[13px] font-medium text-zinc-700 mb-1.5">Expression</label>
              <input id="cron-expression" type="text" class="w-full rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 text-lg text-center font-mono tracking-[0.2em] text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all" value="* * * * *" placeholder="* * * * *" />
            </div>
            
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-[12px] font-medium text-zinc-500 mr-1">Presets:</span>
              <button class="preset-btn rounded-md border border-zinc-200 bg-white px-2 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-cron="* * * * *" type="button">Every min</button>
              <button class="preset-btn rounded-md border border-zinc-200 bg-white px-2 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-cron="0 * * * *" type="button">Hourly</button>
              <button class="preset-btn rounded-md border border-zinc-200 bg-white px-2 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-cron="0 9 * * *" type="button">Daily 9am</button>
              <button class="preset-btn rounded-md border border-zinc-200 bg-white px-2 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-cron="0 0 * * 0" type="button">Weekly (Sun)</button>
            </div>
            
            <div class="grid grid-cols-5 gap-2 pt-2">
              <div class="flex flex-col items-center gap-1.5">
                <input id="cron-min" type="text" class="cron-part w-full rounded-lg border border-zinc-200 bg-white px-1 py-2 text-center font-mono text-sm text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900/5" value="*" data-index="0" />
                <label for="cron-min" class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide">Minute</label>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <input id="cron-hour" type="text" class="cron-part w-full rounded-lg border border-zinc-200 bg-white px-1 py-2 text-center font-mono text-sm text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900/5" value="*" data-index="1" />
                <label for="cron-hour" class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide">Hour</label>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <input id="cron-day" type="text" class="cron-part w-full rounded-lg border border-zinc-200 bg-white px-1 py-2 text-center font-mono text-sm text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900/5" value="*" data-index="2" />
                <label for="cron-day" class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide">Day</label>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <input id="cron-month" type="text" class="cron-part w-full rounded-lg border border-zinc-200 bg-white px-1 py-2 text-center font-mono text-sm text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900/5" value="*" data-index="3" />
                <label for="cron-month" class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide">Month</label>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <input id="cron-weekday" type="text" class="cron-part w-full rounded-lg border border-zinc-200 bg-white px-1 py-2 text-center font-mono text-sm text-zinc-900 focus:border-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900/5" value="*" data-index="4" />
                <label for="cron-weekday" class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide">Weekday</label>
              </div>
            </div>
          </div>
          
          <div class="flex flex-col h-full min-h-[300px] rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden p-5 sm:p-6">
            <div class="flex items-center justify-between mb-4">
              <span class="text-sm font-semibold text-zinc-100">Human Readable</span>
              <button id="cron-copy" class="text-xs font-medium text-indigo-400 hover:text-indigo-300 transition-colors btn-copy" type="button">Copy</button>
            </div>
            <div id="cron-desc" class="text-lg font-medium text-white mb-8">Every minute</div>
            
            <div class="mt-auto">
              <span class="block text-[11px] font-semibold text-zinc-500 mb-3 uppercase tracking-wider">Next 5 executions</span>
              <ul id="cron-next" class="space-y-2 text-[13px] font-mono text-zinc-400"></ul>
            </div>
          </div>
        </div>
      </div>

      <!-- SQL Panel -->
      <div id="panel-sql" role="tabpanel" class="tool-panel hidden" data-panel="sql">
        <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="flex flex-col gap-4 rounded-2xl border border-zinc-200/80 bg-white shadow-sm p-5 sm:p-6">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="flex p-1 rounded-lg bg-zinc-100/80 ring-1 ring-zinc-900/5 w-fit">
                <button id="sql-format-btn" class="mode-btn active" type="button">Format</button>
                <button id="sql-minify-btn" class="mode-btn" type="button">Minify</button>
              </div>
              <label class="flex items-center gap-2 text-sm text-zinc-600 cursor-pointer">
                <input type="checkbox" id="sql-uppercase" class="rounded border-zinc-300 text-zinc-900 focus:ring-zinc-900" checked />
                Uppercase keywords
              </label>
            </div>
            <div>
              <textarea id="sql-input" class="w-full h-64 rounded-xl border border-zinc-200 bg-zinc-50 p-3.5 text-[14px] font-mono leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all resize-y" placeholder="SELECT id, name FROM users WHERE active = 1"></textarea>
            </div>
          </div>
          
          <div class="flex flex-col h-full min-h-[350px] rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 p-3">
              <div class="flex items-center gap-2 px-1">
                <div class="flex gap-1.5">
                  <div class="h-2.5 w-2.5 rounded-full bg-red-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
                </div>
                <span class="ml-2 text-xs font-medium text-zinc-400">Output</span>
              </div>
              <button id="sql-copy" class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-zinc-100 btn-copy" type="button">
                Copy
              </button>
            </div>
            <pre id="sql-output" class="w-full flex-1 border-0 bg-zinc-950 p-4 font-mono text-[13px] leading-relaxed text-zinc-300 overflow-auto m-0">Enter SQL query</pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .tab-btn {
    @apply px-4 py-2 text-[13px] font-medium text-zinc-500 rounded-md transition-all duration-200;
  }
  .tab-btn:hover {
    @apply text-zinc-900;
  }
  .tab-btn.active {
    @apply bg-white text-zinc-900 shadow-sm ring-1 ring-zinc-900/5;
  }
  
  .mode-btn {
    @apply px-4 py-1.5 text-xs font-medium text-zinc-500 rounded-md transition-all duration-200;
  }
  .mode-btn:hover {
    @apply text-zinc-900;
  }
  .mode-btn.active {
    @apply bg-white text-zinc-900 shadow-sm ring-1 ring-zinc-900/5;
  }
  
  .match-hl {
    @apply bg-emerald-400/20 text-emerald-300 rounded-[2px] px-0.5;
  }
</style>

<script>
  // ============ Tab Switching ============
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = document.querySelectorAll<HTMLDivElement>('.tool-panel');

    function switchTab(tabName: string) {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => { p.classList.add('hidden'); p.classList.remove('active'); });
      const activeTab = document.querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${tabName}"]`);
      const activePanel = document.querySelector<HTMLDivElement>(`.tool-panel[data-panel="${tabName}"]`);
      if (activeTab && activePanel) {
        activeTab.classList.add('active');
        activeTab.setAttribute('aria-selected', 'true');
        activePanel.classList.remove('hidden');
        activePanel.classList.add('active');
      }
      window.history.replaceState(null, '', `#${tabName}`);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => switchTab(tab.dataset.tab || 'regex'));
    });

    const hash = window.location.hash.replace('#', '');
    if (['regex', 'base64', 'cron', 'sql'].includes(hash)) switchTab(hash);

    window.addEventListener('hashchange', () => {
      const h = window.location.hash.replace('#', '');
      if (['regex', 'base64', 'cron', 'sql'].includes(h)) switchTab(h);
    });
  }

  // ============ Regex Tester ============
  function initRegex() {
    const patternEl = document.getElementById('regex-pattern') as HTMLInputElement;
    const inputEl = document.getElementById('regex-input') as HTMLTextAreaElement;
    const outputEl = document.getElementById('regex-output') as HTMLDivElement;
    const countEl = document.getElementById('regex-count') as HTMLSpanElement;
    const groupsEl = document.getElementById('regex-groups') as HTMLDivElement;
    const groupsContent = document.getElementById('regex-groups-content') as HTMLPreElement;

    function run() {
      const pattern = patternEl.value;
      const text = inputEl.value;
      if (!pattern || !text) {
        outputEl.textContent = 'Enter regex pattern and test string.';
        countEl.textContent = '0 matches';
        countEl.className = 'text-[11px] font-semibold uppercase tracking-wider text-zinc-400 bg-zinc-800 px-2 py-0.5 rounded';
        groupsEl.classList.add('hidden');
        return;
      }

      let flags = '';
      if ((document.getElementById('flag-g') as HTMLInputElement).checked) flags += 'g';
      if ((document.getElementById('flag-i') as HTMLInputElement).checked) flags += 'i';
      if ((document.getElementById('flag-m') as HTMLInputElement).checked) flags += 'm';
      if ((document.getElementById('flag-s') as HTMLInputElement).checked) flags += 's';

      try {
        const matches = [...text.matchAll(new RegExp(pattern, flags.includes('g') ? flags : flags + 'g'))];
        countEl.textContent = `${matches.length} match${matches.length !== 1 ? 'es' : ''}`;
        if (matches.length > 0) {
          countEl.className = 'text-[11px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded';
        } else {
          countEl.className = 'text-[11px] font-semibold uppercase tracking-wider text-amber-400 bg-amber-400/10 px-2 py-0.5 rounded';
        }

        // Highlight matches
        let html = '';
        let lastIndex = 0;
        const allMatches = [...text.matchAll(new RegExp(pattern, flags.includes('g') ? flags : flags + 'g'))];
        for (const m of allMatches) {
          const start = m.index!;
          const end = start + m[0].length;
          html += escapeHtml(text.slice(lastIndex, start));
          html += `<mark class="match-hl bg-emerald-500/20 text-emerald-300 rounded-[2px] px-0.5 bg-transparent">${escapeHtml(m[0])}</mark>`;
          lastIndex = end;
        }
        html += escapeHtml(text.slice(lastIndex));
        outputEl.innerHTML = html || escapeHtml(text);

        // Groups
        if (matches.length > 0 && matches[0].length > 1) {
          groupsEl.classList.remove('hidden');
          let groupText = '';
          matches.forEach((m, i) => {
            groupText += `Match ${i + 1}: ${JSON.stringify(m[0])}\n`;
            for (let g = 1; g < m.length; g++) {
              groupText += `  Group ${g}: ${JSON.stringify(m[g])}\n`;
            }
          });
          groupsContent.textContent = groupText;
        } else {
          groupsEl.classList.add('hidden');
        }
      } catch (e: any) {
        outputEl.innerHTML = `<span class="text-red-400">Error: ${e.message}</span>`;
        countEl.textContent = 'Error';
        countEl.className = 'text-[11px] font-semibold uppercase tracking-wider text-red-400 bg-red-400/10 px-2 py-0.5 rounded';
        groupsEl.classList.add('hidden');
      }
    }

    patternEl.addEventListener('input', run);
    inputEl.addEventListener('input', run);
    document.querySelectorAll('.regex-flags input').forEach(el => el.addEventListener('change', run));
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function encodeBase64(text: string): string {
    const bytes = new TextEncoder().encode(text);
    let binary = '';
    bytes.forEach((byte) => {
      binary += String.fromCharCode(byte);
    });
    return btoa(binary);
  }

  function decodeBase64(text: string): string {
    const binary = atob(text);
    const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
    return new TextDecoder().decode(bytes);
  }

  // ============ Base64 ============
  function initBase64() {
    const inputEl = document.getElementById('b64-input') as HTMLTextAreaElement;
    const outputEl = document.getElementById('b64-output') as HTMLTextAreaElement;
    const encodeBtn = document.getElementById('b64-encode-btn') as HTMLButtonElement;
    const decodeBtn = document.getElementById('b64-decode-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('b64-copy') as HTMLButtonElement;
    let mode = 'encode';

    function run() {
      const text = inputEl.value;
      if (!text) { outputEl.value = ''; return; }
      try {
        if (mode === 'encode') {
          outputEl.value = encodeBase64(text);
        } else {
          outputEl.value = decodeBase64(text);
        }
      } catch {
        outputEl.value = `❌ ${mode === 'encode' ? 'Encode' : 'Decode'} failed`;
      }
    }

    encodeBtn.addEventListener('click', () => { mode = 'encode'; encodeBtn.classList.add('active'); decodeBtn.classList.remove('active'); run(); });
    decodeBtn.addEventListener('click', () => { mode = 'decode'; decodeBtn.classList.add('active'); encodeBtn.classList.remove('active'); run(); });
    inputEl.addEventListener('input', run);
    copyBtn.addEventListener('click', () => copyText(outputEl.value, copyBtn));
  }

  // ============ Cron Builder ============
  function initCron() {
    const exprEl = document.getElementById('cron-expression') as HTMLInputElement;
    const descEl = document.getElementById('cron-desc') as HTMLDivElement;
    const nextEl = document.getElementById('cron-next') as HTMLUListElement;
    const copyBtn = document.getElementById('cron-copy') as HTMLButtonElement;
    const parts = document.querySelectorAll<HTMLInputElement>('.cron-part');
    const presets = document.querySelectorAll<HTMLButtonElement>('.preset-btn');

    function parseCron() {
      const expr = exprEl.value.trim();
      const fields = expr.split(/\s+/);
      if (fields.length !== 5) { descEl.textContent = '❌ Invalid format (5 fields required)'; nextEl.innerHTML = ''; return; }
      parts.forEach((p, i) => { p.value = fields[i] || '*'; });
      descEl.textContent = describeCron(fields);
      renderNextRuns(fields);
    }

    function syncFromParts() {
      const vals: string[] = [];
      parts.forEach(p => vals.push(p.value || '*'));
      exprEl.value = vals.join(' ');
      const fields = vals;
      descEl.textContent = describeCron(fields);
      renderNextRuns(fields);
    }

    function describeCron(f: string[]): string {
      const [min, hour, day, month, weekday] = f;
      const parts: string[] = [];

      if (min === '*' && hour === '*' && day === '*' && month === '*' && weekday === '*') return 'Every minute';
      if (min === '0' && hour === '*' && day === '*' && month === '*' && weekday === '*') return 'Every hour at minute 0';
      if (min === '0' && hour !== '*' && day === '*' && month === '*' && weekday === '*') return `Every day at ${hour}:00`;
      if (min === '0' && hour !== '*' && day === '*' && month === '*' && weekday === '1-5') return `Weekdays at ${hour}:00`;
      if (min === '0' && hour === '0' && day === '*' && month === '*' && weekday === '0') return 'Every Sunday at midnight';
      if (min === '0' && hour === '0' && day === '1' && month === '*' && weekday === '*') return 'First day of month at midnight';

      if (min !== '*') parts.push(`minute ${min}`);
      if (hour !== '*') parts.push(`hour ${hour}`);
      if (day !== '*') parts.push(`day ${day}`);
      if (month !== '*') parts.push(`month ${month}`);
      if (weekday !== '*') parts.push(`weekday ${weekday}`);
      return parts.join(', ') || 'Every minute';
    }

    function renderNextRuns(f: string[]) {
      const runs: string[] = [];
      const now = new Date();
      let d = new Date(now);
      for (let i = 0; i < 5000 && runs.length < 5; i++) {
        d = new Date(d.getTime() + 60000);
        if (matchesCron(f, d)) {
          runs.push(d.toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }));
        }
      }
      nextEl.innerHTML = runs.map(r => `<li>${r}</li>`).join('');
    }

    function matchesCron(f: string[], d: Date): boolean {
      const vals = [d.getMinutes(), d.getHours(), d.getDate(), d.getMonth() + 1, d.getDay()];
      return f.every((field, i) => matchField(field, vals[i]));
    }

    function matchField(field: string, value: number): boolean {
      if (field === '*') return true;
      return field.split(',').some(part => {
        if (part.includes('/')) {
          const [range, step] = part.split('/');
          const s = parseInt(step);
          if (range === '*') return value % s === 0;
          const start = parseInt(range);
          return value >= start && (value - start) % s === 0;
        }
        if (part.includes('-')) {
          const [a, b] = part.split('-').map(Number);
          return value >= a && value <= b;
        }
        return parseInt(part) === value;
      });
    }

    exprEl.addEventListener('input', parseCron);
    parts.forEach(p => p.addEventListener('input', syncFromParts));
    presets.forEach(btn => {
      btn.addEventListener('click', () => {
        exprEl.value = btn.dataset.cron || '* * * * *';
        parseCron();
      });
    });
    copyBtn.addEventListener('click', () => copyText(exprEl.value, copyBtn));
    parseCron();
  }

  // ============ SQL Formatter ============
  function initSQL() {
    const inputEl = document.getElementById('sql-input') as HTMLTextAreaElement;
    const outputEl = document.getElementById('sql-output') as HTMLPreElement;
    const formatBtn = document.getElementById('sql-format-btn') as HTMLButtonElement;
    const minifyBtn = document.getElementById('sql-minify-btn') as HTMLButtonElement;
    const uppercaseEl = document.getElementById('sql-uppercase') as HTMLInputElement;
    const copyBtn = document.getElementById('sql-copy') as HTMLButtonElement;
    let mode = 'format';

    const SQL_KEYWORDS = ['SELECT','FROM','WHERE','AND','OR','NOT','IN','ON','AS','JOIN','LEFT','RIGHT','INNER','OUTER','FULL','CROSS','NATURAL','GROUP BY','ORDER BY','HAVING','LIMIT','OFFSET','UNION','ALL','INSERT','INTO','VALUES','UPDATE','SET','DELETE','CREATE','TABLE','ALTER','DROP','INDEX','VIEW','CASE','WHEN','THEN','ELSE','END','DISTINCT','COUNT','SUM','AVG','MIN','MAX','BETWEEN','LIKE','IS','NULL','EXISTS','ASC','DESC','WITH','RECURSIVE'];

    function formatSQL(sql: string): string {
      if (!sql.trim()) return 'Enter SQL query...';
      if (mode === 'minify') {
        return sql.replace(/\s+/g, ' ').replace(/\s*([,()])\s*/g, '$1').trim();
      }

      let formatted = sql.replace(/\s+/g, ' ').trim();

      // Add newlines before major keywords
      const breakBefore = ['SELECT','FROM','WHERE','AND','OR','GROUP BY','ORDER BY','HAVING','LIMIT','OFFSET','UNION','JOIN','LEFT JOIN','RIGHT JOIN','INNER JOIN','FULL JOIN','CROSS JOIN','INSERT INTO','VALUES','UPDATE','SET','DELETE FROM','CREATE TABLE'];
      for (const kw of breakBefore) {
        const re = new RegExp(`\\b${kw}\\b`, 'gi');
        formatted = formatted.replace(re, `\n${kw}`);
      }

      if (uppercaseEl.checked) {
        for (const kw of SQL_KEYWORDS) {
          const re = new RegExp(`\\b${kw}\\b`, 'gi');
          formatted = formatted.replace(re, kw);
        }
      }

      // Indent after SELECT, WHERE, etc.
      const lines = formatted.split('\n').map(l => l.trim()).filter(Boolean);
      const indented: string[] = [];
      let indent = 0;
      for (const line of lines) {
        const upper = line.toUpperCase();
        if (upper.startsWith('SELECT') || upper.startsWith('FROM') || upper.startsWith('WHERE') || upper.startsWith('GROUP BY') || upper.startsWith('ORDER BY') || upper.startsWith('HAVING') || upper.startsWith('LIMIT')) {
          indent = 0;
          indented.push(line);
          indent = 1;
        } else if (upper.startsWith('AND') || upper.startsWith('OR')) {
          indented.push('  ' + line);
        } else {
          indented.push('  '.repeat(indent) + line);
        }
      }

      return indented.join('\n');
    }

    function run() { outputEl.textContent = formatSQL(inputEl.value); }

    formatBtn.addEventListener('click', () => { mode = 'format'; formatBtn.classList.add('active'); minifyBtn.classList.remove('active'); run(); });
    minifyBtn.addEventListener('click', () => { mode = 'minify'; minifyBtn.classList.add('active'); formatBtn.classList.remove('active'); run(); });
    inputEl.addEventListener('input', run);
    uppercaseEl.addEventListener('change', run);
    copyBtn.addEventListener('click', () => copyText(outputEl.textContent || '', copyBtn));
  }

  // ============ Helpers ============
  async function copyText(text: string, btn: HTMLButtonElement) {
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('text-emerald-400');
      setTimeout(() => { 
        btn.textContent = orig; 
        btn.classList.remove('text-emerald-400');
      }, 1500);
    } catch {
      btn.textContent = 'Failed';
      setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
    }
  }

  // ============ Init ============
  function init() {
    initTabs();
    initRegex();
    initBase64();
    initCron();
    initSQL();
  }

  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>
