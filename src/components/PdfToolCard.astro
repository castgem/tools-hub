---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
}

const { title, description, href, icon, badge } = Astro.props;
---

<a href={href} class="group relative flex flex-col p-6 rounded-2xl border border-zinc-200/80 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-zinc-900/10">
  <div class="absolute inset-0 bg-gradient-to-br from-zinc-50/50 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 rounded-2xl"></div>
  
  <div class="relative z-10 flex flex-col h-full">
    <div class="mb-4 flex items-center justify-between">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-zinc-200/80 bg-zinc-50 text-zinc-700 shadow-sm transition-transform duration-300 group-hover:scale-110" aria-hidden="true" set:html={icon} />
      {badge && (
        <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-600 ring-1 ring-inset ring-emerald-500/20">
          {badge}
        </span>
      )}
    </div>
    
    <h3 class="text-base font-semibold text-zinc-900 mb-2">{title}</h3>
    <p class="text-sm leading-relaxed text-zinc-500 flex-1 mb-5">{description}</p>
    
    <div class="mt-auto flex items-center gap-1.5 text-sm font-medium text-zinc-900 transition-colors">
      <span>Use Tool</span>
      <svg xmlns="http://www.w0.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4 transition-transform duration-300 group-hover:translate-x-1">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
      </svg>
    </div>
  </div>
</a>
