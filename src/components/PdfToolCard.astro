---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
}

const { title, description, href, icon, badge } = Astro.props;
---

<a href={href} class="tool-card">
  {badge && <span class="tool-card-badge">{badge}</span>}
  <span class="tool-card-icon" aria-hidden="true" set:html={icon} />
  <h3 class="tool-card-title">{title}</h3>
  <p class="tool-card-desc">{description}</p>
  <span class="tool-card-cta">Use Tool &rarr;</span>
</a>

<style>
  .tool-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    overflow: hidden;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary);
    text-decoration: none;
    color: var(--text);
  }

  .tool-card-badge {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    padding: 0.2rem 0.6rem;
    background: var(--primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .tool-card-icon {
    font-size: 2rem;
    margin-bottom: 0.875rem;
    display: block;
    line-height: 1;
  }

  .tool-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.375rem;
    color: var(--text);
  }

  .tool-card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    margin: 0 0 1rem;
  }

  .tool-card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary);
    margin-top: auto;
  }
</style>
