---
interface Props {
  title: string;
  description: string;
  backLabel?: string;
  backHref?: string;
  badge?: string;
}

const { title, description, backLabel, backHref, badge } = Astro.props;
---

<section class="pt-4 pb-8">
  <div class="section-shell">
    <div class="max-w-4xl">
      {badge && (
        <div class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs font-medium text-zinc-600 shadow-sm mb-4">
          <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
          <span>{badge}</span>
        </div>
      )}
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 sm:text-4xl">
          {title}
        </h1>
        {backLabel && backHref && (
          <a href={backHref} class="hidden sm:inline-flex items-center gap-1 shrink-0 mt-2 text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
            ← {backLabel}
          </a>
        )}
      </div>
      <p class="mt-3 text-lg leading-relaxed text-zinc-500">
        {description}
      </p>
    </div>
  </div>
</section>
