---
---

<section class="json-workbench w-full max-w-7xl mx-auto">
  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div class="flex flex-col h-[calc(100vh-12rem)] min-h-[600px] rounded-2xl border border-zinc-200/80 bg-white shadow-sm overflow-hidden flex-shrink-0">
      <div class="flex flex-wrap gap-1 p-3 border-b border-zinc-100 bg-zinc-50/50" role="tablist" aria-label="JSON Convertor tools">
        <button class="json-tab rounded-lg px-3 py-1.5 text-sm font-medium transition-all duration-200" data-tab="json" aria-selected="true" role="tab">JSON Formatter</button>
        <button class="json-tab rounded-lg px-3 py-1.5 text-sm font-medium transition-all duration-200" data-tab="curl" aria-selected="false" role="tab">cURL to Code</button>
        <button class="json-tab rounded-lg px-3 py-1.5 text-sm font-medium transition-all duration-200" data-tab="jwt" aria-selected="false" role="tab">JWT Decode</button>
      </div>

      <div class="json-panel flex flex-col flex-1" data-panel="json" role="tabpanel">
        <div class="flex-1 relative">
          <textarea id="json-input" class="absolute inset-0 w-full h-full resize-none border-0 bg-transparent p-4 font-mono text-[13px] text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-0" spellcheck={false} placeholder='{"user":{"id":1,"name":"Ada"}}'></textarea>
        </div>
        <div class="border-t border-zinc-100 bg-white p-3 flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap items-center gap-2">
            <button id="json-format" class="btn btn--primary btn--sm" type="button">Format</button>
            <button id="json-minify" class="btn btn--secondary btn--sm" type="button">Minify</button>
            <button id="json-typescript" class="btn btn--secondary btn--sm" type="button">To TypeScript</button>
          </div>
          <button id="json-sample" class="text-xs font-medium text-zinc-500 hover:text-zinc-900 transition-colors" type="button">Load Sample</button>
        </div>
        <div id="json-error-wrap" class="hidden border-t border-red-100 bg-red-50 p-3">
          <p id="json-error" class="text-[13px] font-medium text-red-600"></p>
        </div>
      </div>

      <div class="json-panel hidden flex flex-col flex-1" data-panel="curl" role="tabpanel">
        <div class="flex-1 relative">
          <textarea id="curl-input" class="absolute inset-0 w-full h-full resize-none border-0 bg-transparent p-4 font-mono text-[13px] text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-0" spellcheck={false} placeholder={"curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{\"name\":\"Ada\"}'"}></textarea>
        </div>
        <div class="border-t border-zinc-100 bg-white p-3 flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap items-center gap-2">
            <button id="curl-fetch" class="btn btn--primary btn--sm" type="button">To Fetch</button>
            <button id="curl-axios" class="btn btn--secondary btn--sm" type="button">To Axios</button>
          </div>
          <button id="curl-sample" class="text-xs font-medium text-zinc-500 hover:text-zinc-900 transition-colors" type="button">Load Sample</button>
        </div>
      </div>

      <div class="json-panel hidden flex flex-col flex-1" data-panel="jwt" role="tabpanel">
        <div class="flex-1 relative">
          <textarea id="jwt-input" class="absolute inset-0 w-full h-full resize-none border-0 bg-transparent p-4 font-mono text-[13px] text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-0 break-all" spellcheck={false} placeholder="eyJhbGciOi..."></textarea>
        </div>
        <div class="border-t border-zinc-100 bg-white p-3 flex flex-wrap items-center justify-between gap-3">
          <button id="jwt-decode" class="btn btn--primary btn--sm" type="button">Decode Payload</button>
          <button id="jwt-sample" class="text-xs font-medium text-zinc-500 hover:text-zinc-900 transition-colors" type="button">Load Sample</button>
        </div>
      </div>
    </div>

    <div class="flex flex-col h-[calc(100vh-12rem)] min-h-[600px] rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden flex-shrink-0">
      <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 p-3">
        <div class="flex items-center gap-2 px-1">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-red-500/80"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
          </div>
          <span class="ml-2 text-xs font-medium text-zinc-400">Output</span>
        </div>
        <button id="json-copy-output" class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-zinc-100" type="button">
          <svg xmlns="http://www.w0.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
          </svg>
          <span class="copy-text">Copy</span>
        </button>
      </div>
      <div class="flex-1 relative bg-zinc-950">
        <pre id="json-output" class="absolute inset-0 w-full h-full overflow-auto p-4 font-mono text-[13px] leading-relaxed text-zinc-300"><code>Result will appear here.</code></pre>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const tabs = [...document.querySelectorAll(".json-tab")];
  const panels = [...document.querySelectorAll(".json-panel")];
  const outputEl = document.getElementById("json-output");
  const copyBtn = document.getElementById("json-copy-output");
  const errorEl = document.getElementById("json-error");
  const errorWrap = document.getElementById("json-error-wrap");

  function setOutput(value) {
    // Basic syntax highlighting hack for visual flair in dark mode
    if (typeof value === 'string' && value.startsWith('{') || value.startsWith('[')) {
      outputEl.innerHTML = value
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
          let cls = 'text-blue-300'; // number
          if (/^"/.test(match)) {
            if (/:$/.test(match)) {
              cls = 'text-indigo-300'; // key
            } else {
              cls = 'text-emerald-300'; // string
            }
          } else if (/true|false/.test(match)) {
            cls = 'text-amber-300'; // boolean
          } else if (/null/.test(match)) {
            cls = 'text-rose-300'; // null
          }
          return '<span class="' + cls + '">' + match + '</span>';
        });
    } else {
      outputEl.textContent = value;
    }
  }

  function setError(message) {
    if (!message) {
      errorWrap.classList.add("hidden");
      errorEl.textContent = "";
      return;
    }
    errorWrap.classList.remove("hidden");
    errorEl.textContent = message;
  }

  function activateTab(name) {
    tabs.forEach((tab) => {
      const active = tab.dataset.tab === name;
      tab.setAttribute("aria-selected", active ? "true" : "false");
      tab.classList.toggle("bg-white", active);
      tab.classList.toggle("text-zinc-900", active);
      tab.classList.toggle("shadow-sm", active);
      tab.classList.toggle("ring-1", active);
      tab.classList.toggle("ring-zinc-900/5", active);
      tab.classList.toggle("text-zinc-500", !active);
      tab.classList.toggle("hover:text-zinc-900", !active);
      tab.classList.toggle("hover:bg-zinc-100/50", !active);
    });
    panels.forEach((panel) => panel.classList.toggle("hidden", panel.dataset.panel !== name));
    setError("");
  }

  tabs.forEach((tab) => tab.addEventListener("click", () => activateTab(tab.dataset.tab)));
  activateTab("json");

  const sampleJson = {
    user: { id: 1, name: "Ada Lovelace", admin: true },
    roles: ["editor", "maintainer"],
    metadata: { createdAt: "2026-03-25T12:00:00Z", score: 98.2 }
  };

  const sampleCurl = "curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -H 'Authorization: Bearer TOKEN' -d '{\"name\":\"Ada\",\"role\":\"maintainer\"}'";
  const sampleJwt = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTYiLCJuYW1lIjoiQWRhIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c";

  document.getElementById("json-sample").addEventListener("click", () => {
    document.getElementById("json-input").value = JSON.stringify(sampleJson, null, 2);
    setOutput(JSON.stringify(sampleJson, null, 2));
  });

  function inferType(value, name = "RootObject") {
    const interfaces = [];

    function walk(current, currentName) {
      if (Array.isArray(current)) {
        if (current.length === 0) return "unknown[]";
        return `${walk(current[0], `${currentName}Item`)}[]`;
      }
      if (current === null) return "null";
      if (typeof current === "object") {
        const lines = Object.entries(current).map(([key, val]) => `  ${key}: ${walk(val, `${currentName}${key[0].toUpperCase()}${key.slice(1)}`)};`);
        interfaces.push(`interface ${currentName} {\n${lines.join("\n")}\n}`);
        return currentName;
      }
      if (typeof current === "string") return "string";
      if (typeof current === "number") return "number";
      if (typeof current === "boolean") return "boolean";
      return "unknown";
    }

    walk(value, name);
    return interfaces.reverse().join("\n\n");
  }

  function parseJsonInput() {
    const raw = document.getElementById("json-input").value.trim();
    if (!raw) {
      setError("Paste JSON first.");
      return null;
    }
    try {
      setError("");
      return JSON.parse(raw);
    } catch (error) {
      setError(error.message);
      return null;
    }
  }

  document.getElementById("json-format").addEventListener("click", () => {
    const parsed = parseJsonInput();
    if (!parsed) return;
    setOutput(JSON.stringify(parsed, null, 2));
  });

  document.getElementById("json-minify").addEventListener("click", () => {
    const parsed = parseJsonInput();
    if (!parsed) return;
    setOutput(JSON.stringify(parsed));
  });

  document.getElementById("json-typescript").addEventListener("click", () => {
    const parsed = parseJsonInput();
    if (!parsed) return;
    setOutput(inferType(parsed));
  });

  function parseCurl(raw) {
    const methodMatch = raw.match(/-X\s+(\w+)/i);
    const urlMatch = raw.match(/curl\s+(?:-X\s+\w+\s+)?([^\s]+)/i);
    const headerMatches = [...raw.matchAll(/-H\s+['"]([^'"]+)['"]/g)].map((m) => m[1]);
    const dataMatch = raw.match(/-d\s+['"]([\s\S]*?)['"]/i);
    return {
      method: methodMatch ? methodMatch[1].toUpperCase() : "GET",
      url: urlMatch ? urlMatch[1] : "https://api.example.com",
      headers: Object.fromEntries(headerMatches.map((header) => {
        const index = header.indexOf(":");
        return [header.slice(0, index).trim(), header.slice(index + 1).trim()];
      })),
      data: dataMatch ? dataMatch[1] : "",
    };
  }

  function toFetchCode(parsed) {
    const headerLines = Object.keys(parsed.headers).length ? `headers: ${JSON.stringify(parsed.headers, null, 2)},\n  ` : "";
    const bodyLine = parsed.data ? `body: ${JSON.stringify(parsed.data)},\n  ` : "";
    return `fetch(${JSON.stringify(parsed.url)}, {\n  method: ${JSON.stringify(parsed.method)},\n  ${headerLines}${bodyLine}})\n  .then((response) => response.json())\n  .then((data) => console.log(data));`;
  }

  function toAxiosCode(parsed) {
    const config = {
      method: parsed.method.toLowerCase(),
      url: parsed.url,
      headers: parsed.headers,
      data: parsed.data || undefined,
    };
    return `import axios from "axios";\n\naxios(${JSON.stringify(config, null, 2)})\n  .then((response) => console.log(response.data));`;
  }

  document.getElementById("curl-sample").addEventListener("click", () => {
    document.getElementById("curl-input").value = sampleCurl;
    setOutput(toFetchCode(parseCurl(sampleCurl)));
  });

  document.getElementById("curl-fetch").addEventListener("click", () => {
    const raw = document.getElementById("curl-input").value.trim();
    if (!raw) {
      setError("Paste a curl command first.");
      return;
    }
    setError("");
    setOutput(toFetchCode(parseCurl(raw)));
  });

  document.getElementById("curl-axios").addEventListener("click", () => {
    const raw = document.getElementById("curl-input").value.trim();
    if (!raw) {
      setError("Paste a curl command first.");
      return;
    }
    setError("");
    setOutput(toAxiosCode(parseCurl(raw)));
  });

  function decodeBase64Url(value) {
    const normalized = value.replace(/-/g, "+").replace(/_/g, "/");
    const padded = normalized.padEnd(normalized.length + (4 - normalized.length % 4) % 4, "=");
    return decodeURIComponent(Array.from(atob(padded)).map((char) => `%${char.charCodeAt(0).toString(16).padStart(2, "0")}`).join(""));
  }

  document.getElementById("jwt-sample").addEventListener("click", () => {
    document.getElementById("jwt-input").value = sampleJwt;
    document.getElementById("jwt-decode").click();
  });

  document.getElementById("jwt-decode").addEventListener("click", () => {
    const raw = document.getElementById("jwt-input").value.trim();
    if (!raw) {
      setError("Paste a JWT first.");
      return;
    }
    const parts = raw.split(".");
    if (parts.length !== 3) {
      setError("JWT must have exactly 3 parts.");
      return;
    }
    try {
      const header = JSON.parse(decodeBase64Url(parts[0]));
      const payload = JSON.parse(decodeBase64Url(parts[1]));
      setError("");
      setOutput(`Header\n${JSON.stringify(header, null, 2)}\n\nPayload\n${JSON.stringify(payload, null, 2)}\n\nSignature\n${parts[2]}`);
    } catch (error) {
      setError(`Failed to decode JWT: ${error.message}`);
    }
  });

  copyBtn.addEventListener("click", async () => {
    try {
      const text = outputEl.innerText || outputEl.textContent;
      await navigator.clipboard.writeText(text || "");
      const span = copyBtn.querySelector(".copy-text");
      span.textContent = "Copied!";
      copyBtn.classList.add("text-emerald-400");
      setTimeout(() => {
        span.textContent = "Copy";
        copyBtn.classList.remove("text-emerald-400");
      }, 2000);
    } catch {
      const span = copyBtn.querySelector(".copy-text");
      span.textContent = "Failed";
      copyBtn.classList.add("text-red-400");
      setTimeout(() => {
        span.textContent = "Copy";
        copyBtn.classList.remove("text-red-400");
      }, 2000);
    }
  });
</script>
