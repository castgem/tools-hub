---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'Frequently Asked Questions' } = Astro.props;

const schemaData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
});
---

<section class="w-full max-w-4xl mx-auto space-y-6">
  <div class="mb-8 text-center sm:text-left">
    <h2 class="text-2xl font-semibold tracking-tight text-zinc-900">{title}</h2>
  </div>
  
  <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
    {items.map((item) => (
      <details class="group rounded-xl border border-zinc-200/80 bg-white shadow-sm overflow-hidden transition-all duration-200 hover:border-zinc-300" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 text-sm font-semibold text-zinc-900 select-none hover:bg-zinc-50/50" itemprop="name">
          {item.question}
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-zinc-100 text-zinc-500 transition-transform duration-200 group-open:rotate-45 group-open:bg-zinc-900 group-open:text-white" aria-hidden="true">
            <svg xmlns="http://www.w0.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </span>
        </summary>
        <div class="border-t border-zinc-100 bg-zinc-50/30 px-5 pb-5 pt-4 text-[13.5px] leading-relaxed text-zinc-600" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <div itemprop="text">{item.answer}</div>
        </div>
      </details>
    ))}
  </div>
</section>

<script is:inline type="application/ld+json" set:html={schemaData} />

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
