---
---
<section id="tool" class="w-full max-w-5xl mx-auto space-y-6">
  <div class="tool-wrapper flex flex-col gap-6">
    <div class="tool-input-area rounded-2xl border border-zinc-200/80 bg-white shadow-sm p-6 sm:p-8">
      <label for="prompt-input" class="block text-sm font-semibold text-zinc-900 mb-3">Your Idea</label>
      <div class="relative">
        <textarea
          id="prompt-input"
          class="w-full min-h-[140px] rounded-xl border border-zinc-200 bg-zinc-50 p-4 text-[14px] leading-relaxed text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-4 focus:ring-zinc-900/5 transition-all resize-y"
          placeholder="例如：帮我写一个翻译助手，能把中文翻译成地道的英文&#10;&#10;Example: Help me create a translation assistant that translates Chinese to natural English"
        ></textarea>
      </div>
      
      <div class="mt-4 flex flex-wrap gap-3">
        <button id="refine-btn" class="btn btn--primary" type="button">
          <svg xmlns="http://www.w0.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.381Z" clip-rule="evenodd" />
          </svg>
          Refine Prompt
        </button>
        <button id="clear-btn" class="btn btn--secondary" type="button">
          Clear
        </button>
      </div>

      <div class="mt-6 pt-6 border-t border-zinc-100 flex flex-wrap items-center gap-2">
        <span class="text-[13px] text-zinc-500 mr-2">Try examples:</span>
        <button class="example-btn rounded-md border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-example="帮我做一个代码审查助手，能找出代码中的bug和改进建议" type="button">Code Reviewer</button>
        <button class="example-btn rounded-md border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-example="我需要一个英语口语教练，能纠正我的语法错误并给出更自然的表达" type="button">English Coach</button>
        <button class="example-btn rounded-md border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-50 hover:text-zinc-900" data-example="帮我创建一个周报生成器，把零散的工作内容整理成专业的周报" type="button">Weekly Report</button>
      </div>
    </div>

    <div id="output-area" class="hidden rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm overflow-hidden flex-col">
      <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/50 p-4 sm:px-6">
        <div class="flex items-center gap-2.5">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-red-500/80"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-emerald-500/80"></div>
          </div>
          <h3 class="text-sm font-semibold text-zinc-100 ml-2">Generated System Prompt</h3>
        </div>
        <div class="flex gap-2">
          <button id="retry-btn" class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs font-medium text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-zinc-100" type="button">
            <svg xmlns="http://www.w0.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Retry
          </button>
          <button id="copy-btn" class="inline-flex items-center gap-1.5 rounded-md bg-white/10 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-white/20 btn-copy" type="button">
            <svg xmlns="http://www.w0.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
            </svg>
            <span class="copy-text">Copy</span>
          </button>
        </div>
      </div>
      <div class="relative bg-zinc-950 p-4 sm:p-6 max-h-[500px] overflow-y-auto">
        <pre id="prompt-output" class="font-mono text-[13px] leading-relaxed text-zinc-300 whitespace-pre-wrap break-words"><code></code></pre>
      </div>
      <div class="border-t border-zinc-800 bg-zinc-900 p-4 sm:px-6">
        <div class="flex items-start gap-2.5 rounded-lg bg-indigo-500/10 border border-indigo-500/20 p-3">
          <svg xmlns="http://www.w0.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4 text-indigo-400 mt-0.5 shrink-0">
            <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
          </svg>
          <p class="text-[13px] text-indigo-200/80">Copy this System Prompt into the custom instructions or system message of ChatGPT, Claude, or any AI platform.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .shake {
    animation: shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }
  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
    40%, 60% { transform: translate3d(4px, 0, 0); }
  }
</style>

<script>
  function detectLanguage(text: string): 'zh' | 'en' | 'mixed' {
    const chineseChars = text.match(/[\u4e00-\u9fff]/g) || [];
    const englishWords = text.match(/[a-zA-Z]+/g) || [];
    const zhRatio = chineseChars.length / (text.length || 1);
    if (zhRatio > 0.3) return chineseChars.length > 0 && englishWords.length > 3 ? 'mixed' : 'zh';
    return 'en';
  }

  function extractTaskInfo(input: string): { role: string; task: string; context: string; lang: 'zh' | 'en' | 'mixed' } {
    const lang = detectLanguage(input);
    const cleaned = input.trim();

    let role = '';
    let task = '';
    let context = '';

    if (lang === 'zh' || lang === 'mixed') {
      const roleMatch = cleaned.match(/(?:做|写|创建|设计|当|充当|扮演)(?:一个|个)?(.{2,15}?)(?:[，,。.；;]|$)/);
      role = roleMatch ? roleMatch[1].trim() : '智能助手';

      const taskMatch = cleaned.match(/(?:能|可以|帮我|用来|负责)(.+?)(?:[，,。.]|$)/);
      task = taskMatch ? taskMatch[1].trim() : cleaned;

      context = cleaned;
    } else {
      const roleMatch = cleaned.match(/(?:create|build|make|write|act as|be|design)\s+(?:a|an|the)?\s*(.{3,30}?)(?:[,.]|\s+that|\s+which|\s+to)/i);
      role = roleMatch ? roleMatch[1].trim() : 'AI Assistant';

      const taskMatch = cleaned.match(/(?:that|which|to|can|should|will)\s+(.+?)(?:[,.]|$)/i);
      task = taskMatch ? taskMatch[1].trim() : cleaned;

      context = cleaned;
    }

    return { role, task, context, lang };
  }

  function generateSystemPrompt(input: string): string {
    const { role, task, context, lang } = extractTaskInfo(input);

    if (lang === 'zh' || lang === 'mixed') {
      return `# 角色定义
你是一个专业的${role}。你的核心职责是为用户提供高质量、精准的服务。

# 核心任务
${task}

# 用户原始需求
${context}

# 行为准则
1. **专业性**：始终保持专业态度，提供准确、有价值的回答
2. **结构化输出**：回答应该条理清晰，使用适当的格式（标题、列表、代码块等）
3. **主动性**：在完成任务的同时，主动指出潜在问题和改进建议
4. **语言适配**：根据用户的语言偏好回复，默认使用中文

# 输出格式
- 使用 Markdown 格式组织内容
- 重要信息使用**加粗**标注
- 步骤性内容使用有序列表
- 代码或专业术语使用 \`行内代码\` 格式

# 约束条件
- 如果不确定用户意图，先确认再执行
- 不编造不存在的信息
- 承认自身局限性，必要时建议用户寻求专业帮助
- 保持回答简洁，避免不必要的冗余

# 交互风格
友好但专业，像一个经验丰富的${role}同事在与你对话。`;
    }

    return `# Role Definition
You are a professional ${role}. Your primary responsibility is to deliver high-quality, accurate assistance to the user.

# Core Task
${task}

# Original User Request
${context}

# Behavioral Guidelines
1. **Expertise**: Maintain a professional demeanor and provide accurate, valuable responses
2. **Structured Output**: Organize responses clearly using appropriate formatting (headings, lists, code blocks)
3. **Proactivity**: While completing the task, proactively identify potential issues and suggest improvements
4. **Language Adaptation**: Respond in the user's preferred language

# Output Format
- Use Markdown formatting to organize content
- Highlight important information with **bold text**
- Use ordered lists for step-by-step content
- Use \`inline code\` for technical terms and code references

# Constraints
- If the user's intent is unclear, ask for clarification before proceeding
- Do not fabricate information that does not exist
- Acknowledge limitations and suggest professional help when necessary
- Keep responses concise and avoid unnecessary verbosity

# Interaction Style
Friendly yet professional, like an experienced ${role} colleague having a conversation with you.`;
  }

  function init() {
    const inputEl = document.getElementById('prompt-input') as HTMLTextAreaElement;
    const outputArea = document.getElementById('output-area') as HTMLDivElement;
    const outputEl = document.querySelector('#prompt-output code') as HTMLElement;
    const refineBtn = document.getElementById('refine-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;
    const exampleBtns = document.querySelectorAll('.example-btn');

    refineBtn.addEventListener('click', () => {
      const input = inputEl.value.trim();
      if (!input) {
        inputEl.focus();
        inputEl.classList.add('shake');
        setTimeout(() => inputEl.classList.remove('shake'), 400);
        return;
      }
      const result = generateSystemPrompt(input);
      outputEl.textContent = result;
      outputArea.classList.remove('hidden');
      outputArea.classList.add('flex');
      outputArea.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputArea.classList.add('hidden');
      outputArea.classList.remove('flex');
      outputEl.textContent = '';
      inputEl.focus();
    });

    copyBtn.addEventListener('click', async () => {
      const text = outputEl.textContent || '';
      const span = copyBtn.querySelector('.copy-text');
      if (!span) return;
      
      try {
        await navigator.clipboard.writeText(text);
        span.textContent = 'Copied!';
        copyBtn.classList.add('text-emerald-400');
        setTimeout(() => { 
          span.textContent = 'Copy';
          copyBtn.classList.remove('text-emerald-400');
        }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        span.textContent = 'Failed';
        setTimeout(() => { span.textContent = 'Copy'; }, 2000);
        document.body.removeChild(ta);
      }
    });

    retryBtn.addEventListener('click', () => {
      const input = inputEl.value.trim();
      if (!input) return;
      const result = generateSystemPrompt(input);
      outputEl.textContent = result;
    });

    exampleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const example = (btn as HTMLElement).dataset.example || '';
        inputEl.value = example;
        inputEl.focus();
      });
    });
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') {
    init();
  } else {
    document.addEventListener('DOMContentLoaded', init);
  }
</script>
