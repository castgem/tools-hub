---
---
<section id="tool" class="tool-section section">
  <div class="container">
    <h2 class="section-title">开始优化你的提示词</h2>
    <p class="section-subtitle">输入一句简单的想法，一键生成结构化 System Prompt</p>

    <div class="tool-wrapper">
      <div class="tool-input-area">
        <label for="prompt-input" class="input-label">你的想法 / Your idea</label>
        <textarea
          id="prompt-input"
          class="prompt-textarea"
          placeholder="例如：帮我写一个翻译助手，能把中文翻译成地道的英文&#10;&#10;Example: Help me create a translation assistant that translates Chinese to natural English"
          rows="5"
        ></textarea>
        <div class="tool-actions">
          <button id="refine-btn" class="btn-primary" type="button">
            ⚡ 优化提示词 / Refine Prompt
          </button>
          <button id="clear-btn" class="btn-secondary" type="button">
            清除 / Clear
          </button>
        </div>
        <div class="example-prompts">
          <span class="example-label">试试这些例子：</span>
          <button class="example-btn" data-example="帮我做一个代码审查助手，能找出代码中的bug和改进建议" type="button">代码审查助手</button>
          <button class="example-btn" data-example="我需要一个英语口语教练，能纠正我的语法错误并给出更自然的表达" type="button">口语教练</button>
          <button class="example-btn" data-example="帮我创建一个周报生成器，把零散的工作内容整理成专业的周报" type="button">周报生成器</button>
          <button class="example-btn" data-example="I want an AI that helps me brainstorm startup ideas based on my skills and interests" type="button">Startup Ideas</button>
          <button class="example-btn" data-example="帮我写一个面试模拟器，能根据职位描述生成面试问题并给出反馈" type="button">面试模拟器</button>
        </div>
      </div>

      <div id="output-area" class="tool-output-area" style="display: none;">
        <div class="output-header">
          <h3>生成的 System Prompt</h3>
          <div class="output-actions">
            <button id="copy-btn" class="btn-copy" type="button">
              📋 复制 / Copy
            </button>
            <button id="retry-btn" class="btn-secondary btn-sm" type="button">
              🔄 重新生成
            </button>
          </div>
        </div>
        <pre id="prompt-output" class="prompt-output"><code></code></pre>
        <p class="output-tip">💡 将此 System Prompt 粘贴到 ChatGPT、Claude、GPT-4 或任何 AI 对话的系统设置中即可使用。</p>
      </div>
    </div>
  </div>
</section>

<script>
  function detectLanguage(text: string): 'zh' | 'en' | 'mixed' {
    const chineseChars = text.match(/[\u4e00-\u9fff]/g) || [];
    const englishWords = text.match(/[a-zA-Z]+/g) || [];
    const zhRatio = chineseChars.length / (text.length || 1);
    if (zhRatio > 0.3) return chineseChars.length > 0 && englishWords.length > 3 ? 'mixed' : 'zh';
    return 'en';
  }

  function extractTaskInfo(input: string): { role: string; task: string; context: string; lang: 'zh' | 'en' | 'mixed' } {
    const lang = detectLanguage(input);
    const cleaned = input.trim();

    let role = '';
    let task = '';
    let context = '';

    if (lang === 'zh' || lang === 'mixed') {
      const roleMatch = cleaned.match(/(?:做|写|创建|设计|当|充当|扮演)(?:一个|个)?(.{2,15}?)(?:[，,。.；;]|$)/);
      role = roleMatch ? roleMatch[1].trim() : '智能助手';

      const taskMatch = cleaned.match(/(?:能|可以|帮我|用来|负责)(.+?)(?:[，,。.]|$)/);
      task = taskMatch ? taskMatch[1].trim() : cleaned;

      context = cleaned;
    } else {
      const roleMatch = cleaned.match(/(?:create|build|make|write|act as|be|design)\s+(?:a|an|the)?\s*(.{3,30}?)(?:[,.]|\s+that|\s+which|\s+to)/i);
      role = roleMatch ? roleMatch[1].trim() : 'AI Assistant';

      const taskMatch = cleaned.match(/(?:that|which|to|can|should|will)\s+(.+?)(?:[,.]|$)/i);
      task = taskMatch ? taskMatch[1].trim() : cleaned;

      context = cleaned;
    }

    return { role, task, context, lang };
  }

  function generateSystemPrompt(input: string): string {
    const { role, task, context, lang } = extractTaskInfo(input);

    if (lang === 'zh' || lang === 'mixed') {
      return `# 角色定义
你是一个专业的${role}。你的核心职责是为用户提供高质量、精准的服务。

# 核心任务
${task}

# 用户原始需求
${context}

# 行为准则
1. **专业性**：始终保持专业态度，提供准确、有价值的回答
2. **结构化输出**：回答应该条理清晰，使用适当的格式（标题、列表、代码块等）
3. **主动性**：在完成任务的同时，主动指出潜在问题和改进建议
4. **语言适配**：根据用户的语言偏好回复，默认使用中文

# 输出格式
- 使用 Markdown 格式组织内容
- 重要信息使用**加粗**标注
- 步骤性内容使用有序列表
- 代码或专业术语使用 \`行内代码\` 格式

# 约束条件
- 如果不确定用户意图，先确认再执行
- 不编造不存在的信息
- 承认自身局限性，必要时建议用户寻求专业帮助
- 保持回答简洁，避免不必要的冗余

# 交互风格
友好但专业，像一个经验丰富的${role}同事在与你对话。`;
    }

    return `# Role Definition
You are a professional ${role}. Your primary responsibility is to deliver high-quality, accurate assistance to the user.

# Core Task
${task}

# Original User Request
${context}

# Behavioral Guidelines
1. **Expertise**: Maintain a professional demeanor and provide accurate, valuable responses
2. **Structured Output**: Organize responses clearly using appropriate formatting (headings, lists, code blocks)
3. **Proactivity**: While completing the task, proactively identify potential issues and suggest improvements
4. **Language Adaptation**: Respond in the user's preferred language

# Output Format
- Use Markdown formatting to organize content
- Highlight important information with **bold text**
- Use ordered lists for step-by-step content
- Use \`inline code\` for technical terms and code references

# Constraints
- If the user's intent is unclear, ask for clarification before proceeding
- Do not fabricate information that does not exist
- Acknowledge limitations and suggest professional help when necessary
- Keep responses concise and avoid unnecessary verbosity

# Interaction Style
Friendly yet professional, like an experienced ${role} colleague having a conversation with you.`;
  }

  function init() {
    const inputEl = document.getElementById('prompt-input') as HTMLTextAreaElement;
    const outputArea = document.getElementById('output-area') as HTMLDivElement;
    const outputEl = document.querySelector('#prompt-output code') as HTMLElement;
    const refineBtn = document.getElementById('refine-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;
    const exampleBtns = document.querySelectorAll('.example-btn');

    refineBtn.addEventListener('click', () => {
      const input = inputEl.value.trim();
      if (!input) {
        inputEl.focus();
        inputEl.classList.add('shake');
        setTimeout(() => inputEl.classList.remove('shake'), 500);
        return;
      }
      const result = generateSystemPrompt(input);
      outputEl.textContent = result;
      outputArea.style.display = 'block';
      outputArea.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputArea.style.display = 'none';
      outputEl.textContent = '';
      inputEl.focus();
    });

    copyBtn.addEventListener('click', async () => {
      const text = outputEl.textContent || '';
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = '✅ 已复制!';
        setTimeout(() => { copyBtn.textContent = '📋 复制 / Copy'; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyBtn.textContent = '✅ 已复制!';
        setTimeout(() => { copyBtn.textContent = '📋 复制 / Copy'; }, 2000);
      }
    });

    retryBtn.addEventListener('click', () => {
      const input = inputEl.value.trim();
      if (!input) return;
      const result = generateSystemPrompt(input);
      outputEl.textContent = result;
    });

    exampleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const example = (btn as HTMLElement).dataset.example || '';
        inputEl.value = example;
        inputEl.focus();
      });
    });
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') {
    init();
  } else {
    document.addEventListener('DOMContentLoaded', init);
  }
</script>

<style>
  .tool-section {
    padding-top: 2rem;
  }

  .tool-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .tool-input-area {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .input-label {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .prompt-textarea {
    width: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 1rem;
    resize: vertical;
    line-height: 1.6;
    transition: border-color 0.2s;
  }

  .prompt-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .prompt-textarea.shake {
    animation: shake 0.4s ease-in-out;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  .tool-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.25rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text);
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }

  .example-prompts {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .example-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .example-btn {
    background: var(--color-primary-light);
    color: var(--color-primary);
    border: 1px solid transparent;
    border-radius: 20px;
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .example-btn:hover {
    border-color: var(--color-primary);
    background: rgba(108, 92, 231, 0.2);
  }

  .tool-output-area {
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 1.5rem;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .output-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .output-header h3 {
    color: var(--color-accent);
    font-size: 1rem;
  }

  .output-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-copy {
    background: var(--color-accent-light);
    color: var(--color-accent);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-copy:hover {
    border-color: var(--color-accent);
  }

  .prompt-output {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    overflow-x: auto;
    font-size: 0.88rem;
    line-height: 1.7;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-family: var(--font-mono);
    color: var(--color-text);
    max-height: 500px;
    overflow-y: auto;
  }

  .output-tip {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    padding: 0.75rem;
    background: var(--color-primary-light);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 768px) {
    .tool-actions {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
      text-align: center;
    }

    .output-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
