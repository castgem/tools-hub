---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDirectory from '../../components/CategoryDirectory.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Dev Tools',
    url: 'https://usetooleasy.com/dev-tools/',
    description: 'Browser-based developer utilities for JSON editing, text formatting, regex testing, cron building, encoding, and SQL formatting.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What kind of tools are included in the Dev Tools section?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The current dev-tools directory includes JSON Convertor, Text Formatter, and Modern DevBox. Together they cover JSON workflows, text cleanup, regex, Base64, cron, and SQL formatting.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why group these developer tools under one domain?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Developers often need multiple quick browser utilities in the same session. Grouping them under one domain preserves trust, navigation, and internal linking while still keeping each child page focused on one main intent.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do these tools upload data to a server?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. The dev-tools section is designed around browser-based processing, so JSON, text, regex, SQL, and token data stay in your browser during launch.',
        },
      },
    ],
  },
]);
---

<BaseLayout
  title="Free Online Dev Tools — JSON, Text, Regex, Cron & SQL | UseToolEasy"
  description="Free online developer tools and coding utilities: JSON formatter, text converter, regex tester, cron builder, and SQL formatter. Web developer toolkit, no signup needed."
  canonicalPath="/dev-tools/"
  schemaMarkup={schemaMarkup}
>
  <CategoryDirectory
    categoryId="dev-tools"
    title="Developer Tools"
    description="Format code, convert data structures, and validate configurations instantly in your browser."
    introHeading="Why use these tools for development?"
    introParagraphs={[
      'JSON debugging, text cleanup, regex testing, cron building, and SQL formatting are not random features. They are the short browser tasks developers bounce between all day.',
      'Grouping them under one category reduces tab sprawl, but the site still keeps a clear route per intent so each child page can stay narrow enough for SEO and user clarity.',
    ]}
    valueCards={[
      {
        title: 'Suite-level discoverability',
        description: 'The category page can rank for grouped dev-tool queries without forcing all feature terms onto one bloated page.',
      },
      {
        title: 'Child-page clarity',
        description: 'Each child route still targets one dominant cluster such as JSON, text formatting, or regex/Cron/SQL.',
      },
    ]}
    useCasesHeading="Typical use cases"
    useCasesDescription="This directory is built for the short technical jobs that happen between shipping steps, not for heavyweight IDE replacement."
    useCases={[
      {
        title: 'API payload cleanup',
        description: 'Format JSON, inspect JWT payloads, and convert curl snippets before they hit docs or code.',
      },
      {
        title: 'Text transformation',
        description: 'Normalize casing, deduplicate lines, encode values, and clean text without switching between micro-sites.',
      },
      {
        title: 'Micro utility work',
        description: 'Handle regex, Base64, cron, and SQL formatting tasks from one shared developer-friendly directory.',
      },
    ]}
    scopeTitle="Directory scope"
    scopeItems={[
      { label: 'Primary audience', value: 'Developers, technical writers, and operators doing fast browser-side utility work.' },
      { label: 'Current tools', value: 'JSON Convertor, Text Formatter, and Modern DevBox.' },
      { label: 'Processing model', value: 'Browser-first with focused child routes and shared trust pages.' },
      { label: 'SEO role', value: 'Own grouped developer utility queries while child routes focus on transactional tasks.' },
    ]}
  />
</BaseLayout>
