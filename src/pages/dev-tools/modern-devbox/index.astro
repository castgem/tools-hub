---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolTabs from '../../../components/ToolTabs.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Modern DevBox',
    url: 'https://tools.example.com/dev-tools/modern-devbox/',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'A browser-based CyberChef alternative with regex testing, Base64 encode/decode, cron building, and SQL formatting.',
  },
]);
---

<BaseLayout
  title="Modern DevBox — Regex, Base64, Cron, and SQL Formatter"
  description="A modern CyberChef and DevToys alternative for regex testing, Base64 encode/decode, cron building, and SQL formatting in one browser-first developer tool page."
  canonicalPath="/dev-tools/modern-devbox/"
  schemaMarkup={schemaMarkup}
>
  <section class="bg-white py-16">
    <div class="section-shell">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-700">Micro dev tools</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Modern DevBox</h1>
        <p class="mt-4 text-lg leading-8 text-slate-600">
          A modern browser-based alternative to CyberChef, DevToys, and regex101 for the quick jobs you want to finish without leaving the browser: regex testing, Base64, cron, and SQL formatting.
        </p>
      </div>
      <div class="mt-10 rounded-[28px] bg-slate-950 p-2">
        <div class="devbox-theme rounded-[24px]">
          <ToolTabs />
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-16">
    <div class="section-shell prose-copy">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900">Why this page stays separate</h2>
      <p>
        Regex, Base64, cron, and SQL formatting are related because they all behave like quick developer micro-tools. The comparison intent is also distinct: users search for alternatives to CyberChef, DevToys, regex101, and crontab.guru.
      </p>
      <p>
        That comparison language does not belong on the JSON page or on the general text formatter page. Keeping this child route focused protects intent and makes the grouped site easier to navigate.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="section-shell">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="card p-6">
          <h2 class="text-xl font-semibold text-slate-900">Alternative positioning</h2>
          <p class="mt-3 text-slate-600">This route owns the “CyberChef alternative” and “DevToys web version” language in the grouped site because it solves the same micro-tool workflow with less friction.</p>
        </article>
        <article class="card p-6">
          <h2 class="text-xl font-semibold text-slate-900">Privacy and speed</h2>
          <p class="mt-3 text-slate-600">Everything runs client-side, which is especially important when users paste internal regex samples, SQL, or snippets they do not want to ship to a third-party server.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .devbox-theme {
    --color-bg: #0b0e14;
    --color-surface: #141821;
    --color-surface-hover: #1c2030;
    --color-border: #242937;
    --color-text: #e6e8f0;
    --color-text-secondary: #a0a6b8;
    --color-primary: #0ea5e9;
    --color-primary-hover: #38bdf8;
    --color-primary-light: rgba(14, 165, 233, 0.12);
    --color-accent: #22d3ee;
    --color-match: rgba(250, 204, 21, 0.3);
    --font-sans: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
    --radius: 12px;
    --radius-sm: 8px;
  }
</style>
