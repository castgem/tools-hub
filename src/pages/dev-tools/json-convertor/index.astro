---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import JsonWorkbench from '../../../components/JsonWorkbench.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'JSON Convertor',
    url: 'https://usetooleasy.com/dev-tools/json-convertor/',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Format and validate JSON, generate TypeScript, convert curl to code, and decode JWTs in one browser-based page.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What can JSON Convertor do?',
        acceptedAnswer: { '@type': 'Answer', text: 'JSON Convertor formats and validates JSON, infers TypeScript interfaces, converts curl commands into code snippets, and decodes JWT payloads locally in the browser.' },
      },
      {
        '@type': 'Question',
        name: 'Does JSON Convertor upload my data?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. JSON, curl commands, and JWT tokens are processed locally in your browser in this grouped-site launch.' },
      },
    ],
  },
]);
---

<BaseLayout
  title="JSON Convertor — JSON, Curl, JWT, and TypeScript Tools"
  description="A browser-based JSON utility page for formatting, validation, TypeScript generation, curl-to-code conversion, and JWT decoding."
  canonicalPath="/dev-tools/json-convertor/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="JSON Convertor"
    description="Format JSON, convert curl, inspect JWTs, and generate starter TypeScript interfaces without leaving the browser."
    badge="Local processing only"
    backLabel="Back to Dev Tools"
    backHref="/dev-tools/"
  />

  <section>
    <div class="section-shell">
      <JsonWorkbench />
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell">
      <div class="max-w-3xl mb-12">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900">Why this page works</h2>
        <p class="mt-4 text-zinc-600 leading-relaxed">
          Most JSON jobs are adjacent. You usually format a payload, check whether it is valid, convert a curl snippet, or inspect a JWT in the same session. This route stays tight around that workflow instead of mixing in broader text cleanup or unrelated micro-tools.
        </p>
      </div>
      
      <div class="grid gap-6 md:grid-cols-3">
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h3 class="text-[15px] font-semibold text-zinc-900">JSON formatting</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Paste raw API responses and immediately switch between prettified and minified output without leaving the browser.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h3 class="text-[15px] font-semibold text-zinc-900">TypeScript generation</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Turn sample payloads into starter interfaces quickly when you need a schema sketch for front-end work.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h3 class="text-[15px] font-semibold text-zinc-900">Curl and JWT helpers</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Convert documented curl commands into code and decode JWTs locally during auth debugging sessions.</p>
        </article>
      </div>
      
      <div class="mt-8 rounded-2xl border border-zinc-200/60 bg-zinc-100/50 p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h3 class="text-[15px] font-semibold text-zinc-900">Related developer tools</h3>
          <p class="mt-1 text-sm text-zinc-500">Need broader text cleanup or regex-based manipulation around your payloads?</p>
        </div>
        <div class="flex gap-3">
          <a href="/dev-tools/text-formatter/" class="btn btn--secondary btn--sm">Text Formatter</a>
          <a href="/dev-tools/modern-devbox/" class="btn btn--secondary btn--sm">Modern DevBox</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
