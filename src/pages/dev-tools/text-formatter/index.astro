---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import TextFormatter from '../../../components/TextFormatter.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Text Formatter',
    url: 'https://usetooleasy.com/dev-tools/text-formatter/',
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Free browser-based text formatter with case conversion, cleanup, line sorting, encoding, extraction, and word-count workflows.',
  },
]);
---

<BaseLayout
  title="Text Formatter — Clean, Convert, Encode, and Count Text"
  description="An all-in-one browser text formatter for case conversion, whitespace cleanup, encoding, line sorting, extraction, and word counting."
  canonicalPath="/dev-tools/text-formatter/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Text Formatter"
    description="Clean up text, convert case, sort lines, encode values, extract emails and URLs, and count words in one browser-only route. This page owns the high-frequency text utility cluster inside the dev-tools directory."
    badge="Fast, local string manipulation"
    backLabel="Back to Dev Tools"
    backHref="/dev-tools/"
  />

  <section>
    <div class="section-shell">
      <TextFormatter />
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell">
      <div class="max-w-3xl mb-12">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900">What makes this page useful?</h2>
        <p class="mt-4 text-zinc-600 leading-relaxed">
          Many users do not want a dozen different text utilities open in separate tabs. They want one place to uppercase text, remove blank lines, deduplicate lists, encode URLs, and check counts. This page keeps those jobs together because the underlying intent is still “fix or transform text now.”
        </p>
        <p class="mt-4 text-zinc-600 leading-relaxed">
          That is different from the JSON/API debugging cluster and from the regex/cron/SQL cluster. Grouping those all into one page would reduce clarity for both users and search engines.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h2 class="text-[15px] font-semibold text-zinc-900">Text cleanup</h2>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Remove whitespace noise, blank lines, duplicates, and inconsistent casing before you paste content elsewhere.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h2 class="text-[15px] font-semibold text-zinc-900">Encoding and extraction</h2>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Use one route for URL and Base64 operations, email extraction, URL extraction, and light HTML cleanup.</p>
        </article>
        <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
          <h2 class="text-[15px] font-semibold text-zinc-900">Live stats</h2>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500">Word counts, line counts, and reading-time estimates update immediately while you work.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
