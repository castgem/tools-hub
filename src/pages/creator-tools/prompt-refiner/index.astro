---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import PromptRefiner from '../../../components/PromptRefiner.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Prompt Refiner',
  url: 'https://usetooleasy.com/creator-tools/prompt-refiner/',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Turn a rough idea into a structured system prompt in Chinese or English.',
  inLanguage: ['zh-CN', 'en'],
});
---

<BaseLayout
  title="Prompt Refiner — 免费 AI 提示词优化工具"
  description="Turn a rough idea into a structured AI system prompt, clarify role, task, constraints, and output format, and refine Chinese or English prompts locally."
  canonicalPath="/creator-tools/prompt-refiner/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Prompt Refiner"
    description="把一句简单想法转化为结构化 System Prompt。这个页面适合需要快速整理角色、任务、约束、输出格式的人，不需要登录，也不需要 API。"
    backLabel="Back to Creator Tools"
    backHref="/creator-tools/"
  />

  <section>
    <div class="section-shell">
      <PromptRefiner />
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-zinc-900">中文优先</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">这个 route 对中文和中英混合输入尤其友好，适合国内常见的 prompt 起草习惯。</p>
      </article>
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-zinc-900">Related tools</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500"><a href="/creator-tools/writetune/" class="font-medium text-indigo-600 hover:text-indigo-700">Writetune</a> 适合在输出阶段继续处理文本语气和可读性。</p>
      </article>
    </div>
  </section>
</BaseLayout>
