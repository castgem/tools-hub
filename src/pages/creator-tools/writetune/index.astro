---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HumanizerTool from '../../../components/HumanizerTool.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Writetune',
  url: 'https://tools.example.com/creator-tools/writetune/',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Humanize AI-generated text with tone controls and browser-side rewriting.',
});
---

<BaseLayout
  title="Writetune — Humanize AI Text in Your Browser"
  description="Rewrite AI-generated text so it sounds more natural, human, and tone-appropriate, then compare tone shifts without sending content to a server."
  canonicalPath="/creator-tools/writetune/"
  schemaMarkup={schemaMarkup}
>
  <section class="bg-gradient-to-br from-fuchsia-50 to-white py-16">
    <div class="section-shell max-w-4xl">
      <a href="/creator-tools/" class="text-sm font-medium text-brand-700 no-underline hover:text-brand-800">← Back to Creator Tools</a>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Writetune</h1>
      <p class="mt-4 text-lg text-slate-600">
        Paste AI-written text, choose the tone you want, and get a more natural version back instantly. This route is for people who want a lighter, browser-first humanizer instead of a gated SaaS editor.
      </p>
    </div>
  </section>

  <HumanizerTool />

  <section class="pb-16">
    <div class="section-shell grid gap-6 md:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Academic tone</h2>
        <p class="mt-3 text-slate-600">Useful for essays, research summaries, and structured writing that still needs to sound less robotic.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Business tone</h2>
        <p class="mt-3 text-slate-600">Useful for outreach emails, docs, and messaging that needs polish without artificial stiffness.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <p class="mt-3 text-slate-600"><a href="/creator-tools/prompt-refiner/" class="text-brand-700">Prompt Refiner</a> helps upstream when the problem is prompt quality rather than output tone.</p>
      </article>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white py-16">
    <div class="section-shell">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div class="prose-copy">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">When is Writetune the right route?</h2>
          <p>
            Writetune is for the moment when a draft already exists but still sounds stiff, synthetic, or mismatched to the reader. That could be a cold email drafted with AI, a marketing paragraph that needs to sound more grounded, or a study note that became too robotic after summarization.
          </p>
          <p>
            This page intentionally stays focused on rewrite quality rather than pretending to be a full writing suite. The related creator routes solve adjacent problems: <strong>Prompt Refiner</strong> improves the upstream prompt, while <strong>Social Profiler</strong> checks the metadata and preview surface after the final copy is ready to publish.
          </p>
          <p>
            Keeping that distinction clear helps both users and SEO. People searching for an AI humanizer or rewrite helper should land on this route, not on a generic category page that mixes prompts, previews, and social planning into one vague promise.
          </p>
        </div>
        <div class="card bg-slate-950 p-6 text-slate-100">
          <h2 class="text-xl font-semibold text-white">Best-fit use cases</h2>
          <ul class="mt-4 space-y-3 text-sm">
            <li><strong class="text-brand-200">Emails:</strong> make outreach feel less templated</li>
            <li><strong class="text-brand-200">Blog drafts:</strong> soften over-optimized AI phrasing</li>
            <li><strong class="text-brand-200">Study notes:</strong> keep structure while sounding clearer</li>
            <li><strong class="text-brand-200">Social copy:</strong> adjust tone before publishing</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
