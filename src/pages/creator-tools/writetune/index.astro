---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import HumanizerTool from '../../../components/HumanizerTool.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Writetune',
  url: 'https://usetooleasy.com/creator-tools/writetune/',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Humanize AI-generated text with tone controls and browser-side rewriting.',
});
---

<BaseLayout
  title="Writetune — Humanize AI Text in Your Browser"
  description="Rewrite AI-generated text so it sounds more natural, human, and tone-appropriate, then compare tone shifts without sending content to a server."
  canonicalPath="/creator-tools/writetune/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Writetune"
    description="Paste AI-written text, choose the tone you want, and get a more natural version back instantly. This route is for people who want a lighter, browser-first humanizer instead of a gated SaaS editor."
    backLabel="Back to Creator Tools"
    backHref="/creator-tools/"
  />

  <section>
    <div class="section-shell">
      <HumanizerTool />
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell grid gap-6 md:grid-cols-3">
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Academic tone</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Useful for essays, research summaries, and structured writing that still needs to sound less robotic.</p>
      </article>
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Business tone</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Useful for outreach emails, docs, and messaging that needs polish without artificial stiffness.</p>
      </article>
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Related tools</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500"><a href="/creator-tools/prompt-refiner/" class="font-medium text-indigo-600 hover:text-indigo-700">Prompt Refiner</a> helps upstream when the problem is prompt quality rather than output tone.</p>
      </article>
    </div>
  </section>
</BaseLayout>
