---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SocialMetaPreviewTool from '../../../components/SocialMetaPreviewTool.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Social Profiler',
  url: 'https://tools.example.com/creator-tools/social-profiler/',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Preview how links appear on Google, X, Facebook, and LinkedIn before publishing.',
});
---

<BaseLayout
  title="Social Profiler — Preview Link Cards Before You Share"
  description="Preview Open Graph, Twitter card, and Google snippet metadata before you publish or share your link."
  canonicalPath="/creator-tools/social-profiler/"
  schemaMarkup={schemaMarkup}
>
  <section class="bg-gradient-to-br from-rose-50 to-white py-16">
    <div class="section-shell max-w-4xl">
      <a href="/creator-tools/" class="text-sm font-medium text-brand-700 no-underline hover:text-brand-800">← Back to Creator Tools</a>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Social Profiler</h1>
      <p class="mt-4 text-lg text-slate-600">
        Check how a page title, meta description, and social image will appear across Google, X, Facebook, and LinkedIn before you publish. This route is for creators and marketers who want fewer broken previews and higher click confidence.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="section-shell">
      <SocialMetaPreviewTool />
    </div>
  </section>

  <section class="pb-16">
    <div class="section-shell grid gap-6 md:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Best for launch posts</h2>
        <p class="mt-3 text-slate-600">Check title length, description fit, and image coverage before a new product page or blog post goes live.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Best for SEO handoffs</h2>
        <p class="mt-3 text-slate-600">Writers and developers can align on how metadata should actually look, not just what the raw tags say.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <p class="mt-3 text-slate-600"><a href="/creator-tools/xhunter/" class="text-brand-700">XHunter</a> helps you draft the post after you validate the preview.</p>
      </article>
    </div>
  </section>
</BaseLayout>
