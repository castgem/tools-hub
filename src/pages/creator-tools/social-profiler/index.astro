---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import SocialMetaPreviewTool from '../../../components/SocialMetaPreviewTool.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Social Profiler',
  url: 'https://usetooleasy.com/creator-tools/social-profiler/',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Preview how links appear on Google, X, Facebook, and LinkedIn before publishing.',
});
---

<BaseLayout
  title="Social Profiler — Preview Link Cards Before You Share"
  description="Preview Open Graph, Twitter card, and Google snippet metadata before you publish or share your link, and catch preview issues before launch."
  canonicalPath="/creator-tools/social-profiler/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Social Profiler"
    description="Check how a page title, meta description, and social image will appear across Google, X, Facebook, and LinkedIn before you publish. This route is for creators and marketers who want fewer broken previews and higher click confidence."
    backLabel="Back to Creator Tools"
    backHref="/creator-tools/"
  />

  <section>
    <div class="section-shell">
      <SocialMetaPreviewTool />
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell grid gap-6 md:grid-cols-3">
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Best for launch posts</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Check title length, description fit, and image coverage before a new product page or blog post goes live.</p>
      </article>
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Best for SEO handoffs</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Writers and developers can align on how metadata should actually look, not just what the raw tags say.</p>
      </article>
      <article class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Related tools</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500"><a href="/creator-tools/xhunter/" class="font-medium text-indigo-600 hover:text-indigo-700">XHunter</a> helps you draft the post after you validate the preview.</p>
      </article>
    </div>
  </section>
</BaseLayout>
