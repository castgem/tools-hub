---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import XGrowthWorkbench from '../../../components/XGrowthWorkbench.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'XHunter',
  url: 'https://tools.example.com/creator-tools/xhunter/',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Draft X threads, reuse templates, and generate stronger replies in the browser.',
});
---

<BaseLayout
  title="XHunter — Thread Maker, Template Library, and Reply Assistant"
  description="Draft X threads, remix post templates, and shape stronger replies without paying for a full growth suite."
  canonicalPath="/creator-tools/xhunter/"
  schemaMarkup={schemaMarkup}
>
  <section class="bg-gradient-to-br from-amber-50 to-white py-16">
    <div class="section-shell max-w-4xl">
      <a href="/creator-tools/" class="text-sm font-medium text-brand-700 no-underline hover:text-brand-800">← Back to Creator Tools</a>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">XHunter</h1>
      <p class="mt-4 text-lg text-slate-600">
        XHunter focuses on the drafting layer of creator growth: turning raw ideas into threads, reusing good structures, and writing replies with more substance. It does not pretend to be a full scheduling or analytics suite.
      </p>
    </div>
  </section>

  <XGrowthWorkbench />

  <section class="pb-16">
    <div class="section-shell grid gap-6 md:grid-cols-2">
      <article class="card p-6">
        <h2 class="text-2xl font-semibold text-slate-900">What this route owns</h2>
        <p class="mt-3 text-slate-600">This page owns the “tweet hunter alternative”, “thread maker”, and “reply assistant” drafting intent inside the creator-tools directory.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-2xl font-semibold text-slate-900">What it does not claim</h2>
        <p class="mt-3 text-slate-600">No X account sync, no auto-posting, no ghost account automation. It is intentionally a browser-side drafting workbench.</p>
      </article>
    </div>
  </section>
</BaseLayout>
