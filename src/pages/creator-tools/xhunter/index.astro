---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import XGrowthWorkbench from '../../../components/XGrowthWorkbench.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'XHunter',
  url: 'https://usetooleasy.com/creator-tools/xhunter/',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Draft X threads, reuse templates, and generate stronger replies in the browser.',
});
---

<BaseLayout
  title="XHunter — Thread Maker and Reply Drafting"
  description="Draft X threads, remix post templates, and shape stronger replies in the browser without paying for a full growth suite."
  canonicalPath="/creator-tools/xhunter/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="XHunter"
    description="XHunter focuses on the drafting layer of creator growth: turning raw ideas into threads, reusing good structures, and writing replies with more substance. It does not pretend to be a full scheduling or analytics suite."
    backLabel="Back to Creator Tools"
    backHref="/creator-tools/"
  />

  <section>
    <div class="section-shell">
      <XGrowthWorkbench />
    </div>
  </section>
</BaseLayout>
