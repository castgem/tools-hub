---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDirectory from '../../components/CategoryDirectory.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Creator Tools',
  url: 'https://usetooleasy.com/creator-tools/',
  description: 'Creator publishing helpers for link previews, X drafting, AI text humanization, and prompt optimization.',
});
---

<BaseLayout
  title="Free Social Media Tools & Creator Utilities Online | UseToolEasy"
  description="Free social media tools for creators: preview link cards, draft X threads, humanize AI text, and refine prompts. Handy online tools, no signup needed."
  canonicalPath="/creator-tools/"
  schemaMarkup={schemaMarkup}
>
  <CategoryDirectory
    categoryId="creator-tools"
    title="Creator Tools"
    description="Optimize, format, and prepare content for social platforms without uploading drafts to random servers."
    introHeading="What belongs in the creator-tools directory?"
    introParagraphs={[
      'This section is for publishing-adjacent jobs that happen before content goes live. That includes checking metadata previews, drafting X threads and reply angles, rewriting stiff AI copy, and turning loose ideas into cleaner prompts.',
      'Grouping them in one directory protects the main domain from mixed intent while letting each child route still own one narrow task and one searchable workflow.',
    ]}
    valueCards={[
      {
        title: 'Suite-level navigation',
        description: 'Creators can move from preview QA to drafting to prompt cleanup without leaving the same site or relearning a new trust layer.',
      },
      {
        title: 'Child-page focus',
        description: 'Each child page stays specific enough to rank for its own workflow instead of collapsing everything into one generic AI creator page.',
      },
    ]}
    useCasesHeading="When should someone use this directory?"
    useCasesDescription="Use this section when the problem is not raw asset processing but publishing quality and content structure."
    useCases={[
      {
        title: 'Preview QA',
        description: 'Check social cards and metadata before pushing a page or campaign live.',
      },
      {
        title: 'Posting systems',
        description: 'Draft stronger X threads, reply angles, and repeatable post structures.',
      },
      {
        title: 'AI cleanup',
        description: 'Humanize stiff AI copy and refine prompts before handing them to a model or a team.',
      },
    ]}
    scopeTitle="Directory scope"
    scopeItems={[
      { label: 'Current launch', value: 'Social Profiler, XHunter, Writetune, and Prompt Refiner.' },
      { label: 'Shared audience', value: 'Creators, marketers, founders, and solo operators refining content before publish.' },
      { label: 'SEO role', value: 'Own category-level creator workflow queries while child routes carry the direct transactional phrases.' },
      { label: 'Shared promise', value: 'Browser-first creator workflows with one trust layer and no heavy suite required.' },
    ]}
  />
</BaseLayout>
