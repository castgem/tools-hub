---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../data/siteNavigation';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'UseToolEasy',
    url: 'https://usetooleasy.com/',
    description: 'Free online tools for developers, creators, and everyone. Web developer toolkit, image tools, social media tools, and document utilities — all browser-based, no signup required.',
  },
]);
---

<BaseLayout
  title="UseToolEasy — Free Online Dev Tools, Media Tools & Handy Utilities"
  description="Free online tools for everyone: developer utilities, image tools, social media tools, and document workflows. All browser-based, no signup, easy to use."
  canonicalPath="/"
  schemaMarkup={schemaMarkup}
>
  <section class="section-shell pt-6 pb-4">
    <div class="max-w-2xl">
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 sm:text-4xl">
        Free online tools, easy to use.
      </h1>
      <p class="mt-3 text-base leading-relaxed text-zinc-500">
        Browser-based developer utilities, image tools, social media helpers, and document workflows. No signup, no uploads, just open and use.
      </p>
    </div>
  </section>

  {categories.map((category) => (
    <section class="section-shell py-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">{category.label}</h2>
        <a href={category.href} class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">View all &rarr;</a>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {category.tools.map((tool) => (
          <a href={tool.href} class="group flex flex-col rounded-xl border border-zinc-200/80 bg-white p-5 shadow-sm transition-all duration-200 hover:border-zinc-300 hover:shadow-md">
            <div class="flex items-center gap-3 mb-2">
              <span class="inline-flex items-center rounded-md bg-zinc-100 px-2 py-0.5 text-[11px] font-medium text-zinc-500">{tool.tag}</span>
            </div>
            <h3 class="text-[15px] font-semibold text-zinc-900 group-hover:text-zinc-700">{tool.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-zinc-500 line-clamp-2 flex-1">{tool.description}</p>
            <div class="mt-3 flex items-center gap-1 text-sm font-medium text-zinc-900">
              <span>Open</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5">
                <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
