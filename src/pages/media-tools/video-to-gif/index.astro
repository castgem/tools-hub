---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import VideoToGif from '../../../components/VideoToGif.tsx';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Video to GIF Converter',
    url: 'https://usetooleasy.com/media-tools/video-to-gif/',
    description: 'Create a GIF from a short video clip in your browser using FFmpeg.wasm.',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Media Tools', item: 'https://usetooleasy.com/media-tools/' },
      { '@type': 'ListItem', position: 2, name: 'Video to GIF', item: 'https://usetooleasy.com/media-tools/video-to-gif/' },
    ],
  },
]);
---

<BaseLayout
  title="Video to GIF — Convert Clips to GIF in Your Browser"
  description="Turn a short MP4 or WebM clip into a GIF with a browser-based workflow powered by FFmpeg.wasm. No upload wall, no watermarks."
  canonicalPath="/media-tools/video-to-gif/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Video to GIF"
    description="Create short animated GIFs from video clips directly in your browser. This page carries one clear transactional intent: make a GIF fast, without bouncing through a general-purpose converter homepage."
    backLabel="Back to Media Tools"
    backHref="/media-tools/"
  />

  <section class="py-16">
    <div class="section-shell">
      <div class="card p-6">
        <VideoToGif client:load />
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-16">
    <div class="section-shell grid gap-6 lg:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Ideal use case</h2>
        <p class="mt-3 text-sm text-slate-600">Perfect for short product demos, reaction clips, meme content, or social snippets that need to loop cleanly.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Why browser-side FFmpeg matters</h2>
        <p class="mt-3 text-sm text-slate-600">The conversion happens locally with FFmpeg.wasm, which helps avoid waiting on remote uploads for short clip workflows.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a href="/media-tools/webp-to-png/" class="cta-link--inline">WebP to PNG</a></li>
          <li><a href="/media-tools/image-optimizer/" class="cta-link--inline">Image Optimizer</a></li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
