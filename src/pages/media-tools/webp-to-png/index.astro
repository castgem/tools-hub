---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import WebpToPng from '../../../components/WebpToPng.tsx';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'WebP to PNG Converter',
    url: 'https://usetooleasy.com/media-tools/webp-to-png/',
    description: 'Convert WebP images to PNG in your browser without uploads.',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert a WebP image to PNG?',
        acceptedAnswer: { '@type': 'Answer', text: 'Drop a WebP file, click the convert button, and download the PNG result immediately in your browser.' },
      },
      {
        '@type': 'Question',
        name: 'Does this WebP to PNG converter upload files?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. The conversion runs locally in the browser using Canvas APIs.' },
      },
    ],
  },
]);
---

<BaseLayout
  title="WebP to PNG Converter — Free, Browser-Based, No Upload"
  description="Convert WebP images to PNG in your browser with one narrow, high-intent workflow built for designers, creators, and quick asset fixes."
  canonicalPath="/media-tools/webp-to-png/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="WebP to PNG Converter"
    description="This page targets one direct job: convert a WebP asset into a PNG fast. It is intentionally narrower than a generic media converter so the page can match a single transactional query."
    backLabel="Back to Media Tools"
    backHref="/media-tools/"
  />

  <section class="py-16">
    <div class="section-shell">
      <WebpToPng client:load />
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-16">
    <div class="section-shell grid gap-6 lg:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Best for design handoffs</h2>
        <p class="mt-3 text-sm text-slate-600">Use this when a design tool exports WebP but your receiving workflow still expects PNG.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Why this route is separate</h2>
        <p class="mt-3 text-sm text-slate-600">A narrow format pair deserves its own search-intent-safe landing page instead of living inside a crowded all-purpose converter.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a href="/media-tools/image-optimizer/" class="cta-link--inline">Image Optimizer</a></li>
          <li><a href="/media-tools/video-to-gif/" class="cta-link--inline">Video to GIF</a></li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
