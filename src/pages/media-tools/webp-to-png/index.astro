---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WebpToPng from '../../../components/WebpToPng.tsx';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'WebP to PNG Converter',
    url: 'https://tools.example.com/media-tools/webp-to-png/',
    description: 'Convert WebP images to PNG in your browser without uploads.',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert a WebP image to PNG?',
        acceptedAnswer: { '@type': 'Answer', text: 'Drop a WebP file, click the convert button, and download the PNG result immediately in your browser.' },
      },
      {
        '@type': 'Question',
        name: 'Does this WebP to PNG converter upload files?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. The conversion runs locally in the browser using Canvas APIs.' },
      },
    ],
  },
]);
---

<BaseLayout
  title="WebP to PNG Converter — Free, Browser-Based, No Upload"
  description="Convert WebP images to PNG in your browser with one narrow, high-intent workflow built for designers, creators, and quick asset fixes."
  canonicalPath="/media-tools/webp-to-png/"
  schemaMarkup={schemaMarkup}
>
  <section class="bg-gradient-to-br from-sky-50 to-white py-16">
    <div class="section-shell max-w-4xl">
      <a href="/media-tools/" class="text-sm font-medium text-brand-700 no-underline hover:text-brand-800">← Back to Media Tools</a>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">WebP to PNG Converter</h1>
      <p class="mt-4 text-lg text-slate-600">
        This page targets one direct job: convert a WebP asset into a PNG fast. It is intentionally narrower than a generic media converter so the page can match a single transactional query.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="section-shell">
      <WebpToPng client:load />
    </div>
  </section>

  <section class="py-12">
    <div class="section-shell grid gap-6 lg:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Best for design handoffs</h2>
        <p class="mt-3 text-sm text-slate-600">Use this when a design tool exports WebP but your receiving workflow still expects PNG.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Why this route is separate</h2>
        <p class="mt-3 text-sm text-slate-600">A narrow format pair deserves its own search-intent-safe landing page instead of living inside a crowded all-purpose converter.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a href="/media-tools/image-optimizer/" class="text-brand-700">Image Optimizer</a></li>
          <li><a href="/media-tools/video-to-gif/" class="text-brand-700">Video to GIF</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="pb-16">
    <div class="section-shell grid gap-6 lg:grid-cols-2">
      <article class="card p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Why people search for WebP to PNG</h2>
        <p class="mt-3 text-slate-600">WebP is great for delivery performance, but a lot of creative workflows still need PNG. Designers use PNG for quick edits, transparent backgrounds, design handoff, and compatibility with older tools that do not accept WebP cleanly.</p>
        <p class="mt-3 text-slate-600">That is why this page is more useful than a giant universal converter. Users arriving here usually have one problem and want to solve it in one click.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-2xl font-semibold text-slate-900">What makes this route SEO-safe</h2>
        <p class="mt-3 text-slate-600">The hub homepage talks about the overall suite. This child page owns the WebP to PNG job-to-be-done. That split keeps the page tightly aligned to one search intent and gives the suite cleaner internal linking opportunities.</p>
        <p class="mt-3 text-slate-600">Adjacent format pairs such as PNG to WebP can become future supporting pages without forcing conflicting conversion terms onto this route.</p>
      </article>
    </div>
  </section>
</BaseLayout>
