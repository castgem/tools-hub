---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    href: '/media-tools/image-optimizer/',
    title: 'Image Optimizer',
    description: 'Compress, resize, and reformat images in bulk without sending files to a server.',
    tag: 'Image compression',
    cta: 'Open image optimizer',
  },
  {
    href: '/media-tools/webp-to-png/',
    title: 'WebP to PNG',
    description: 'Convert a WebP asset into PNG instantly in your browser with one narrow, high-intent workflow.',
    tag: 'Format conversion',
    cta: 'Open WebP to PNG',
  },
  {
    href: '/media-tools/video-to-gif/',
    title: 'Video to GIF',
    description: 'Turn a short clip into a shareable GIF using FFmpeg.wasm in the browser.',
    tag: 'Creator workflow',
    cta: 'Open video to GIF',
  },
  {
    href: '/media-tools/logo-generator/',
    title: 'Logo Generator',
    description: 'Create a fast logo concept with export-ready PNG and SVG output, no signup required.',
    tag: 'Brand assets',
    cta: 'Open logo generator',
  },
];

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Media Tools',
    url: 'https://tools.example.com/media-tools/',
    description: 'Browser-based media tools for image optimization, WebP conversion, video to GIF workflows, and logo generation.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What kinds of tools are included in the Media Tools section?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The current launch includes an image optimizer, a WebP to PNG converter, a Video to GIF workflow, and a browser-based logo generator.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do these media tools upload files to a server?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The grouped site is designed around browser-based processing where feasible. Image optimization, WebP conversion, GIF creation, and logo creation all run locally in your browser in this launch build.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why group these tools under one site?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Designers, creators, and indie builders often need multiple asset workflows in one session. Grouping them under one site reduces tool-hopping while keeping each child page focused on one search intent.',
        },
      },
    ],
  },
]);
---

<BaseLayout
  title="Media Tools — Image, GIF, and Logo Browser Utilities"
  description="The media-tools directory of Browser Tools Hub: image optimization, WebP conversion, Video to GIF workflows, and browser-based logo creation."
  canonicalPath="/media-tools/"
  schemaMarkup={schemaMarkup}
>
  <section class="overflow-hidden bg-gradient-to-br from-brand-900 via-brand-700 to-indigo-700 text-white">
    <div class="section-shell py-16 sm:py-24">
      <div class="max-w-4xl">
        <p class="inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-sm font-medium text-brand-100">
          Browser Tools Hub category
        </p>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight sm:text-6xl">
          Browser-based media tools for creators, designers, and indie builders
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-brand-100">
          Optimize images, convert WebP assets, turn clips into GIFs, and create lightweight logos in one shared suite. Each tool keeps a narrow page intent, but the trust layer and deployment stay unified.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#featured-tools" class="inline-flex items-center rounded-xl bg-white px-5 py-3 font-semibold text-brand-700 no-underline hover:bg-brand-50">
            Explore tools
          </a>
          <a href="/" class="inline-flex items-center rounded-xl border border-white/20 px-5 py-3 font-semibold text-white no-underline hover:bg-white/10">
            Back to all categories
          </a>
        </div>
        <div class="mt-6 flex flex-wrap gap-3 text-sm text-brand-100">
          <span class="rounded-full border border-white/15 px-3 py-1">No signup</span>
          <span class="rounded-full border border-white/15 px-3 py-1">Browser-based processing</span>
          <span class="rounded-full border border-white/15 px-3 py-1">One shared trust layer</span>
        </div>
      </div>
    </div>
  </section>

  <section id="featured-tools" class="py-16">
    <div class="section-shell">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">Featured tools</h2>
        <p class="mt-3 text-lg text-slate-600">
          The category page owns the suite-level story. Each child page owns one primary intent and one clear action.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {tools.map((tool) => (
          <article class="card p-6">
            <p class="text-sm font-medium text-brand-700">{tool.tag}</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-900">{tool.title}</h3>
            <p class="mt-3 text-slate-600">{tool.description}</p>
            <a href={tool.href} class="mt-5 inline-flex items-center text-sm font-semibold text-brand-700 no-underline hover:text-brand-800">
              {tool.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white py-16">
    <div class="section-shell">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">Why group these media tools together?</h2>
          <p class="mt-4 text-slate-600">
            Designers and creators rarely use just one media utility. They optimize images, convert formats, make GIFs, and create small brand assets in the same workflow. This grouped site reduces tool-hopping without collapsing those intents into one generic converter page.
          </p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="card p-5">
              <h3 class="text-lg font-semibold text-slate-900">One shared trust layer</h3>
              <p class="mt-2 text-sm text-slate-600">About, Privacy, and Contact pages stay site-wide, so the child tools inherit a stronger trust surface.</p>
            </div>
            <div class="card p-5">
              <h3 class="text-lg font-semibold text-slate-900">Intent-safe child pages</h3>
              <p class="mt-2 text-sm text-slate-600">Each child route still targets one narrow keyword cluster instead of forcing multiple conflicting actions onto one page.</p>
            </div>
          </div>
        </div>
        <div class="card bg-slate-950 p-6 text-slate-100">
          <h2 class="text-xl font-semibold text-white">Launch taxonomy</h2>
          <ul class="mt-4 space-y-3 text-sm">
            <li><strong class="text-brand-200">Category page:</strong> Media Tools</li>
            <li><strong class="text-brand-200">Child page:</strong> Image Optimizer</li>
            <li><strong class="text-brand-200">Child page:</strong> WebP to PNG</li>
            <li><strong class="text-brand-200">Child page:</strong> Video to GIF</li>
            <li><strong class="text-brand-200">Child page:</strong> Logo Generator</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
