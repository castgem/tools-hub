---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDirectory from '../../components/CategoryDirectory.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Media Tools',
    url: 'https://usetooleasy.com/media-tools/',
    description: 'Browser-based media tools for image optimization, WebP conversion, video to GIF workflows, and logo generation.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What kinds of tools are included in the Media Tools section?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The current launch includes an image optimizer, a WebP to PNG converter, a Video to GIF workflow, and a browser-based logo generator.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do these media tools upload files to a server?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The grouped site is designed around browser-based processing where feasible. Image optimization, WebP conversion, GIF creation, and logo creation all run locally in your browser in this launch build.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why group these tools under one site?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Designers, creators, and indie builders often need multiple asset workflows in one session. Grouping them under one site reduces tool-hopping while keeping each child page focused on one search intent.',
        },
      },
    ],
  },
]);
---

<BaseLayout
  title="Free Image Tools Online — Optimize, Convert & Create | UseToolEasy"
  description="Free online image tools: compress images, convert WebP to PNG, create GIFs from video, and generate logos. Handy media tools, no signup, easy to use."
  canonicalPath="/media-tools/"
  schemaMarkup={schemaMarkup}
>
  <CategoryDirectory
    categoryId="media-tools"
    title="Media Tools"
    description="Optimize images, generate assets, and convert formats directly in your browser without uploading files."
    introHeading="Why run media tasks in the browser?"
    introParagraphs={[
      'Designers and creators rarely use just one media utility. They optimize images, convert formats, make GIFs, and create small brand assets in the same workflow.',
      'This grouped site reduces tool-hopping without collapsing those intents into one generic converter page. The category explains the cluster, while child routes keep one dominant task each.',
    ]}
    valueCards={[
      {
        title: 'One shared trust layer',
        description: 'About, Privacy, and Contact pages stay site-wide, so the child tools inherit a stronger trust surface.',
      },
      {
        title: 'Intent-safe child pages',
        description: 'Each child route still targets one narrow keyword cluster instead of forcing multiple conflicting actions onto one page.',
      },
    ]}
    useCasesHeading="Typical use cases"
    useCasesDescription="This directory is built for quick asset tasks that happen before publishing, launching, or sharing a file."
    useCases={[
      {
        title: 'Image cleanup',
        description: 'Compress screenshots, resize hero assets, and export lighter files for websites or docs.',
      },
      {
        title: 'Format conversion',
        description: 'Turn WebP into PNG or short videos into GIFs without bouncing across multiple single-purpose sites.',
      },
      {
        title: 'Brand asset drafts',
        description: 'Generate quick logo concepts and simple exports for internal demos or launch experiments.',
      },
    ]}
    scopeTitle="Directory scope"
    scopeItems={[
      { label: 'Primary audience', value: 'Creators, designers, indie builders, and operators handling media assets in-browser.' },
      { label: 'Current tools', value: 'Image Optimizer, WebP to PNG, Video to GIF, and Logo Generator.' },
      { label: 'Processing model', value: 'Browser-first media workflows wherever feasible.' },
      { label: 'SEO role', value: 'Capture grouped media utility queries while child routes target direct conversion or creation tasks.' },
    ]}
  />
</BaseLayout>
