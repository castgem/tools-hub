---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import ImageOptimizer from '../../../components/ImageOptimizer.astro';

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Image Optimizer',
    url: 'https://usetooleasy.com/media-tools/image-optimizer/',
    description: 'Compress, resize, and convert images in your browser without uploads.',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Media Tools', item: 'https://usetooleasy.com/media-tools/' },
      { '@type': 'ListItem', position: 2, name: 'Image Optimizer', item: 'https://usetooleasy.com/media-tools/image-optimizer/' },
    ],
  },
]);
---

<BaseLayout
  title="Image Optimizer — Compress and Resize Images in Your Browser"
  description="Optimize images in bulk, resize them, and export JPEG, PNG, or WebP without sending your files to a remote server or juggling multiple image tools."
  canonicalPath="/media-tools/image-optimizer/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="Image Optimizer"
    description="Compress, resize, and export images directly in your browser. This page is designed for the people searching for a fast image optimizer, not a generic converter landing page."
    backLabel="Back to Media Tools"
    backHref="/media-tools/"
  />

  <section class="py-16">
    <ImageOptimizer />
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-16">
    <div class="section-shell grid gap-6 lg:grid-cols-3">
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Best for</h2>
        <p class="mt-3 text-sm text-slate-600">Compressing, resizing, and exporting lighter web images without leaving the browser.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Who it is for</h2>
        <p class="mt-3 text-sm text-slate-600">Bloggers, creators, marketers, and developers who want to reduce image size before publishing.</p>
      </article>
      <article class="card p-6">
        <h2 class="text-xl font-semibold text-slate-900">Related tools</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a href="/media-tools/webp-to-png/" class="cta-link--inline">WebP to PNG</a></li>
          <li><a href="/media-tools/logo-generator/" class="cta-link--inline">Logo Generator</a></li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
