---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolPageHeader from '../../../components/ToolPageHeader.astro';
import PdfFaq from '../../../components/PdfFaq.astro';

const faqItems = [
  {
    question: 'Is PDF Easier browser-based?',
    answer: 'Yes. The grouped-site version is positioned around browser-first PDF workflows so common tasks can stay local when practical.',
  },
  {
    question: 'What jobs should this page cover?',
    answer: 'The core launch jobs are merge PDF, compress PDF, split PDF, rotate PDF, PDF to image, and image to PDF.',
  },
  {
    question: 'Why is this under document-tools instead of media-tools?',
    answer: 'PDF workflows behave like document operations, not media-asset tasks. Keeping them under document-tools protects category clarity and search intent.',
  },
];

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'PDF Easier',
  url: 'https://usetooleasy.com/document-tools/pdf-easier/',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Browser-first PDF workflows for merge, compress, split, rotate, and image conversion.',
});
---

<BaseLayout
  title="PDF Easier — Merge, Compress, Split, and Convert PDFs"
  description="Browser-first PDF workflows for merge, compress, split, rotate, and image conversion under the document-tools directory."
  canonicalPath="/document-tools/pdf-easier/"
  schemaMarkup={schemaMarkup}
>
  <ToolPageHeader
    title="PDF Easier"
    description="PDF Easier is the document-tools route for browser-first PDF jobs. It is designed around the high-frequency operations people search for most: merge, compress, split, rotate, and image conversion workflows."
    badge="Browser-first Processing"
    backLabel="Back to Document Tools"
    backHref="/document-tools/"
  />

  <section class="border-t border-zinc-200/80 bg-zinc-50/50 py-16">
    <div class="section-shell grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <article id="merge-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Merge PDF</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Combine multiple PDFs into one output file without forcing an upload-heavy workflow.</p>
      </article>
      <article id="compress-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Compress PDF</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Reduce file size for email and sharing while keeping the route aligned to compression intent.</p>
      </article>
      <article id="split-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Split PDF</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Extract page ranges cleanly when a user only needs part of a document.</p>
      </article>
      <article id="rotate-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Rotate PDF</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Fix orientation issues without sending the file to a third-party server.</p>
      </article>
      <article id="pdf-to-image-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">PDF to Image</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Convert PDF pages into image assets for previews, slides, or content repurposing.</p>
      </article>
      <article id="image-to-pdf-workflows" class="rounded-2xl border border-zinc-200/60 bg-white p-6 shadow-sm">
        <h2 class="text-[15px] font-semibold text-zinc-900">Image to PDF</h2>
        <p class="mt-2 text-sm leading-relaxed text-zinc-500">Turn JPG or PNG files into a document-ready PDF workflow.</p>
      </article>
    </div>
  </section>

  <section class="border-t border-zinc-200/80 bg-white py-16">
    <div class="section-shell">
      <PdfFaq items={faqItems} title="Frequently Asked Questions" />
    </div>
  </section>
</BaseLayout>
