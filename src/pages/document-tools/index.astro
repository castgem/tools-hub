---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Document Tools',
  url: 'https://tools.example.com/document-tools/',
  description: 'Browser-first document utilities, starting with PDF Easier.',
});
---

<BaseLayout
  title="Document Tools — Browser-First PDF Workflows"
  description="Explore browser-first document tools built for private PDF merge, compress, split, rotate, and image conversion workflows without a heavy desktop app."
  canonicalPath="/document-tools/"
  schemaMarkup={schemaMarkup}
>
  <section class="overflow-hidden bg-gradient-to-br from-sky-950 via-blue-900 to-cyan-700 text-white">
    <div class="section-shell py-16 sm:py-24">
      <div class="max-w-4xl">
        <p class="inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-sm font-medium text-sky-100">
          Browser Tools Hub category
        </p>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight sm:text-6xl">
          Browser-first document workflows for PDFs and related file tasks
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-sky-100">
          This category starts with PDF Easier: a PDF landing route focused on merge, compress, split, convert, and private browser-side processing.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="section-shell max-w-3xl">
      <article class="card p-6">
        <p class="text-sm font-medium text-brand-700">PDF workflows</p>
        <h2 class="mt-3 text-2xl font-semibold text-slate-900">PDF Easier</h2>
        <p class="mt-3 text-slate-600">A document-tools landing route for merge, compress, split, rotate, image conversion, and browser-first PDF tasks.</p>
        <a href="/document-tools/pdf-easier/" class="mt-5 inline-flex items-center text-sm font-semibold text-brand-700 no-underline hover:text-brand-800">
          Open PDF Easier
        </a>
      </article>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white py-16">
    <div class="section-shell">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div class="prose-copy">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">Why start document tools with a PDF-first route?</h2>
          <p>
            PDF tasks are one of the clearest examples of repeat browser utility intent. People usually do not need a full desktop editor; they need one fast route to merge files, compress a bloated export, split a long document, rotate a few pages, or convert between PDF and image formats. That makes PDF a strong first anchor for the document-tools directory.
          </p>
          <p>
            The launch version keeps the directory intentionally narrow. Instead of pretending to be a giant office suite, it uses one private, browser-first route to cover the most frequent document workflows. That keeps the category focused, gives the child page enough depth to target direct conversion and editing queries, and leaves room to add more document routes later if demand is proven.
          </p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="card p-5">
              <h3 class="text-lg font-semibold text-slate-900">Launch use cases</h3>
              <p class="mt-2 text-sm text-slate-600">Merge contracts, compress decks, split long reports, rotate scans, and convert PDFs to images or back again without leaving the browser.</p>
            </div>
            <div class="card p-5">
              <h3 class="text-lg font-semibold text-slate-900">SEO role</h3>
              <p class="mt-2 text-sm text-slate-600">The category page can target grouped PDF-tool queries while the child page focuses on hands-on transactional workflows.</p>
            </div>
          </div>
        </div>
        <div class="card bg-slate-950 p-6 text-slate-100">
          <h2 class="text-xl font-semibold text-white">Directory scope today</h2>
          <ul class="mt-4 space-y-3 text-sm">
            <li><strong class="text-brand-200">Current child route:</strong> PDF Easier</li>
            <li><strong class="text-brand-200">Primary jobs:</strong> merge, compress, split, rotate, convert</li>
            <li><strong class="text-brand-200">Processing model:</strong> browser-first and privacy-conscious</li>
            <li><strong class="text-brand-200">Future expansion:</strong> add more document routes only if they deserve separate intent pages</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
