---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDirectory from '../../components/CategoryDirectory.astro';

const schemaMarkup = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Document Tools',
  url: 'https://usetooleasy.com/document-tools/',
  description: 'Browser-first document utilities, starting with PDF Easier.',
});
---

<BaseLayout
  title="Free Online Document Tools — PDF Merge, Compress & Convert | UseToolEasy"
  description="Free online document tools: merge, compress, split, and convert PDFs in your browser. Handy PDF utilities, no upload required, easy to use."
  canonicalPath="/document-tools/"
  schemaMarkup={schemaMarkup}
>
  <CategoryDirectory
    categoryId="document-tools"
    title="Document Tools"
    description="Merge, split, compress, and edit PDFs directly in your browser without uploading private documents."
    introHeading="Why start document tools with a PDF-first route?"
    introParagraphs={[
      'PDF tasks are one of the clearest examples of repeat browser utility intent. People usually do not need a full desktop editor; they need one fast route to merge files, compress a bloated export, split a long document, rotate a few pages, or convert between PDF and image formats.',
      'The launch version keeps the directory intentionally narrow. Instead of pretending to be a giant office suite, it uses one private, browser-first route to cover the most frequent document workflows.',
    ]}
    valueCards={[
      {
        title: 'Launch use cases',
        description: 'Merge contracts, compress decks, split long reports, rotate scans, and convert PDFs to images or back again without leaving the browser.',
      },
      {
        title: 'SEO role',
        description: 'The category page can target grouped PDF-tool queries while the child page focuses on hands-on transactional workflows.',
      },
    ]}
    useCasesHeading="Where this directory is strongest"
    useCasesDescription="The document directory stays intentionally narrow so the first route can own a strong job-to-be-done instead of pretending to be a full office suite."
    useCases={[
      {
        title: 'Merge and split',
        description: 'Combine contracts, separate reports, or break long PDFs into smaller deliverables.',
      },
      {
        title: 'Compress and rotate',
        description: 'Reduce export size and fix page orientation without leaving the browser or installing a desktop app.',
      },
      {
        title: 'Convert between formats',
        description: 'Move between PDF and image workflows when you need a lighter review or sharing format.',
      },
    ]}
    scopeTitle="Directory scope"
    scopeItems={[
      { label: 'Current child route', value: 'PDF Easier.' },
      { label: 'Primary jobs', value: 'Merge, compress, split, rotate, and convert.' },
      { label: 'Processing model', value: 'Browser-first and privacy-conscious.' },
      { label: 'Future expansion', value: 'Add more document routes only if they deserve separate intent pages.' },
    ]}
  />
</BaseLayout>
